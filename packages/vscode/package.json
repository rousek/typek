{
  "name": "typek-vscode",
  "displayName": "Typek",
  "description": "Syntax highlighting and type checking for Typek typed templates (.tk files)",
  "version": "0.0.1",
  "publisher": "typek",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/index.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "typek-html",
        "aliases": [
          "Typek HTML",
          "tk-html"
        ],
        "extensions": [
          ".html.tk"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "typek-ts",
        "aliases": [
          "Typek TypeScript",
          "tk-ts"
        ],
        "extensions": [
          ".ts.tk"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "typek",
        "aliases": [
          "Typek"
        ],
        "extensions": [
          ".tk"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Typek",
      "properties": {
        "typek.typecheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time type checking of templates."
        },
        "typek.typecheck.debounce": {
          "type": "number",
          "default": 200,
          "minimum": 0,
          "maximum": 5000,
          "description": "Delay in milliseconds before re-checking a template after editing."
        },
        "typek.completions.snippets": {
          "type": "boolean",
          "default": false,
          "description": "Show snippet completions for block tags (e.g. {{#if ...}}...{{/if}})."
        },
        "typek.completions.properties": {
          "type": "boolean",
          "default": true,
          "description": "Show property completions based on the imported type."
        },
        "typek.hover.tagHelp": {
          "type": "boolean",
          "default": true,
          "description": "Show syntax help when hovering over template tags."
        },
        "typek.hover.typeInfo": {
          "type": "boolean",
          "default": true,
          "description": "Show type information when hovering over expressions."
        }
      }
    },
    "grammars": [
      {
        "language": "typek-html",
        "scopeName": "text.html.typek",
        "path": "./syntaxes/typek-html.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.basic": "html"
        }
      },
      {
        "language": "typek-ts",
        "scopeName": "source.ts.typek",
        "path": "./syntaxes/typek-ts.tmLanguage.json",
        "embeddedLanguages": {
          "source.ts": "typescript"
        }
      },
      {
        "language": "typek",
        "scopeName": "text.typek",
        "path": "./syntaxes/typek.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --external:vscode --external:typescript --format=cjs --platform=node --sourcemap",
    "build:tsc": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "pnpm build && vsce package",
    "install-ext": "pnpm build && vsce package --no-dependencies && code --install-extension typek-vscode-0.0.1.vsix --force"
  },
  "dependencies": {
    "@typek/core": "workspace:*",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4"
  },
  "files": [
    "dist",
    "syntaxes",
    "language-configuration.json"
  ],
  "license": "UNLICENSED"
}
