{
  "name": "typecek-vscode",
  "displayName": "Typecek",
  "description": "Syntax highlighting and type checking for Typecek typed templates (.tc files)",
  "version": "0.1.0",
  "publisher": "typecek",
  "engines": {
    "vscode": "^1.110.0"
  },
  "icon": "icons/tc_logo_128.png",
  "categories": [
    "Programming Languages"
  ],
  "main": "./dist/client.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "typecek-html",
        "aliases": [
          "Typecek HTML",
          "tc-html"
        ],
        "extensions": [
          ".html.tc"
        ],
        "icon": {
          "light": "./icons/tc-file.svg",
          "dark": "./icons/tc-file.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "typecek-ts",
        "aliases": [
          "Typecek TypeScript",
          "tc-ts"
        ],
        "extensions": [
          ".ts.tc"
        ],
        "icon": {
          "light": "./icons/tc-file.svg",
          "dark": "./icons/tc-file.svg"
        },
        "configuration": "./language-configuration.json"
      },
      {
        "id": "typecek",
        "aliases": [
          "Typecek"
        ],
        "extensions": [
          ".tc"
        ],
        "icon": {
          "light": "./icons/tc-file.svg",
          "dark": "./icons/tc-file.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Typecek",
      "properties": {
        "typecek.typecheck.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time type checking of templates."
        },
        "typecek.typecheck.debounce": {
          "type": "number",
          "default": 200,
          "minimum": 0,
          "maximum": 5000,
          "description": "Delay in milliseconds before re-checking a template after editing."
        },
        "typecek.completions.snippets": {
          "type": "boolean",
          "default": false,
          "description": "Show snippet completions for block tags (e.g. {{#if ...}}...{{/if}})."
        },
        "typecek.completions.properties": {
          "type": "boolean",
          "default": true,
          "description": "Show property completions based on the imported type."
        },
        "typecek.hover.tagHelp": {
          "type": "boolean",
          "default": true,
          "description": "Show syntax help when hovering over template tags."
        },
        "typecek.hover.typeInfo": {
          "type": "boolean",
          "default": true,
          "description": "Show type information when hovering over expressions."
        }
      }
    },
    "grammars": [
      {
        "language": "typecek-html",
        "scopeName": "text.html.typecek",
        "path": "./syntaxes/typecek-html.tmLanguage.json",
        "embeddedLanguages": {
          "text.html.basic": "html"
        }
      },
      {
        "language": "typecek-ts",
        "scopeName": "source.ts.typecek",
        "path": "./syntaxes/typecek-ts.tmLanguage.json",
        "embeddedLanguages": {
          "source.ts": "typescript"
        }
      },
      {
        "language": "typecek",
        "scopeName": "text.typecek",
        "path": "./syntaxes/typecek.tmLanguage.json"
      },
      {
        "scopeName": "text.html.typecek.injection",
        "path": "./syntaxes/typecek-html-injection.tmLanguage.json",
        "injectTo": [
          "text.html.typecek"
        ]
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/client.ts --bundle --outfile=dist/client.js --external:vscode --format=cjs --platform=node --sourcemap && esbuild src/server.ts --bundle --outfile=dist/server.js --format=cjs --platform=node --sourcemap --main-fields=module,main",
    "build:tsc": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "package": "pnpm build && vsce package",
    "install-ext": "pnpm build && vsce package --no-dependencies && code --install-extension typecek-vscode-0.0.1.vsix --force"
  },
  "dependencies": {
    "@typecek/core": "workspace:*",
    "typescript": "^5.7.0",
    "vscode-css-languageservice": "^6.3.10",
    "vscode-html-languageservice": "^5.6.2",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4"
  },
  "files": [
    "dist",
    "syntaxes",
    "icons",
    "language-configuration.json"
  ],
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rousek/typecek",
    "directory": "packages/vscode"
  }
}
