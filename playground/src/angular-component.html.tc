{{#import User from './types'}}
<div class="component">
  <h1>{{name}}</h1>
  {{#raw}}
  <span>{{ angularExpression | uppercase }}</span>
  <div *ngFor="let item of items">
    {{ item.name }}
  </div>
  {{/raw}}
  <p>Age: {{age}}</p>
  {{#with address}}
    <p>Street: {{street}}</p>
  {{/with}}
</div>
