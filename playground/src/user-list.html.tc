{{#import PageData from "./types"}}
<html>
<head><title>{{title}}</title></head>
<body>
  {{#if showHeader}}
    <h1>{{title}}</h1>
  {{/if}}
  <ul>
    {{#for user in users}}
      <li>{{@index}}. {{user.name}} ({{user.email}})</li>
    {{#empty}}
      <li>No users found.</li>
    {{/empty}}
    {{/for}}
  </ul>
</body>
</html>
