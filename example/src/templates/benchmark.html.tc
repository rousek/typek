{{#import BenchmarkPage from "../models/benchmark-types"}}
{{#layout "../layouts/bench-layout.html.tc" layout}}
{{! ============================================================ }}
{{! Admin Dashboard - Comprehensive Benchmark Template           }}
{{! This template exercises every Typecek feature for benchmarking }}
{{! ============================================================ }}

{{! --- Status Bar --- }}
<header>
  <h1>Admin Dashboard</h1>
  <div class="flex items-center gap-4">
    {{#if errorMessage}}
    <div class="badge text-danger">{{errorMessage}}</div>
    {{/if}}
    {{#if successMessage}}
    <div class="badge text-success">{{successMessage}}</div>
    {{/if}}
    <span class="text-muted">v{{buildVersion}}</span>
    <span>{{currentUser.username}}</span>
    {{#if currentUser.avatar}}
    <img src="{{currentUser.avatar}}" alt="{{currentUser.username}}" width="32" height="32">
    {{#else}}
    <div class="avatar-placeholder">{{currentUser.username}}</div>
    {{/if}}
  </div>
</header>

{{! --- Loading State --- }}
{{#if isLoading}}
<div class="loading-overlay">
  <div class="spinner"></div>
  <p>Loading dashboard data...</p>
</div>
{{/if}}

{{! --- Raw HTML Banner --- }}
<div class="banner-area">
  {{{rawHtmlBanner}}}
</div>

{{! --- Debug Info (raw) --- }}
{{#raw}}
<script>
  // This block is not parsed by Typecek
  console.log("Debug: {{this is raw and not parsed}}");
  var x = {y: "{{literal braces}}"};
</script>
{{/raw}}

{{! --- Whitespace stripping demo --- }}
<div class="breadcrumb">
  {{~currentUser.username~}} / {{~locale~}} / Dashboard
</div>



{{! ============================================================ }}
{{! SECTION: Dashboard Summary Cards                              }}
{{! ============================================================ }}
<section id="dashboard-cards" class="mb-4">
  <h2>Dashboard Overview</h2>
  <div class="grid grid-4">
    {{#for card in dashboardCards}}
    {{> "../partials/bench-card.html.tc" card}}
    {{#empty}}
    <p class="text-muted">No dashboard cards configured.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Analytics Overview                                    }}
{{! ============================================================ }}
<section id="analytics-overview" class="mb-4">
  <h2>Analytics</h2>

  <div class="grid grid-4 mb-4">
    <div class="card">
      <p class="text-muted">Revenue</p>
      <h3>{{currency}}{{analytics.revenue.value}}</h3>
      <p>Previous: {{currency}}{{analytics.revenue.previousValue}}</p>
      {{#switch analytics.revenue.trend}}
      {{#case "up"}}
      <span class="text-success">+{{analytics.revenue.changePercent}}%</span>
      {{/case}}
      {{#case "down"}}
      <span class="text-danger">-{{analytics.revenue.changePercent}}%</span>
      {{/case}}
      {{#case "flat"}}
      <span class="text-muted">No change</span>
      {{/case}}
      {{/switch}}
    </div>

    <div class="card">
      <p class="text-muted">Orders</p>
      <h3>{{analytics.orders.value}}</h3>
      <p>Previous: {{analytics.orders.previousValue}}</p>
      {{#if analytics.orders.changePercent >= 0}}
      <span class="text-success">+{{analytics.orders.changePercent}}%</span>
      {{#else}}
      <span class="text-danger">{{analytics.orders.changePercent}}%</span>
      {{/if}}
    </div>

    <div class="card">
      <p class="text-muted">Customers</p>
      <h3>{{analytics.customers.value}}</h3>
      <p>Previous: {{analytics.customers.previousValue}}</p>
      {{#switch analytics.customers.trend}}
      {{#case "up"}}
      <span class="text-success">Growing</span>
      {{/case}}
      {{#case "down"}}
      <span class="text-danger">Declining</span>
      {{/case}}
      {{#default}}
      <span class="text-muted">Stable</span>
      {{/default}}
      {{/switch}}
    </div>

    <div class="card">
      <p class="text-muted">Conversion Rate</p>
      <h3>{{analytics.conversionRate.value}}%</h3>
      <p>Previous: {{analytics.conversionRate.previousValue}}%</p>
      {{#if analytics.conversionRate.changePercent > 0}}
      <span class="text-success">Improving</span>
      {{#else if analytics.conversionRate.changePercent < 0}}
      <span class="text-danger">Declining</span>
      {{#else}}
      <span class="text-muted">Stable</span>
      {{/if}}
    </div>
  </div>

  {{! --- Period comparison --- }}
  <div class="grid grid-2 mb-4">
    <div class="card">
      <h3>Current Period</h3>
      <p>{{analytics.currentPeriod.startDate}} - {{analytics.currentPeriod.endDate}}</p>
      <p>Revenue: {{currency}}{{analytics.currentPeriod.totalRevenue}}</p>
      <p>Orders: {{analytics.currentPeriod.totalOrders}}</p>
      <p>Avg Order: {{currency}}{{analytics.currentPeriod.averageOrderValue}}</p>
      <p>Conversion: {{analytics.currentPeriod.conversionRate}}%</p>

      <h4>Top Products This Period</h4>
      {{#for product in analytics.currentPeriod.topProducts}}
      <div class="flex justify-between">
        <span>{{product.name}}</span>
        <span>{{currency}}{{product.price}}</span>
      </div>
      {{#empty}}
      <p class="text-muted">No top products this period.</p>
      {{/empty}}
      {{/for}}
    </div>

    <div class="card">
      <h3>Previous Period</h3>
      <p>{{analytics.previousPeriod.startDate}} - {{analytics.previousPeriod.endDate}}</p>
      <p>Revenue: {{currency}}{{analytics.previousPeriod.totalRevenue}}</p>
      <p>Orders: {{analytics.previousPeriod.totalOrders}}</p>
      <p>Avg Order: {{currency}}{{analytics.previousPeriod.averageOrderValue}}</p>
      <p>Conversion: {{analytics.previousPeriod.conversionRate}}%</p>

      <h4>Top Products Previous Period</h4>
      {{#for product in analytics.previousPeriod.topProducts}}
      <div class="flex justify-between">
        <span>{{product.name}}</span>
        <span>{{currency}}{{product.price}}</span>
      </div>
      {{/for}}
    </div>
  </div>

  {{! --- Chart data --- }}
  <div class="card mb-4">
    <h3>Daily Revenue Chart</h3>
    <div class="chart-container">
      {{#for point in analytics.currentPeriod.dailyData}}
      <div class="chart-bar" style="height: {{point.value}}px; background: {{point.color}}">
        <span class="chart-label">{{point.label}}</span>
        <span class="chart-value">{{point.value}}</span>
      </div>
      {{/for}}
    </div>
  </div>

  {{! --- Recent Activity --- }}
  <div class="card mb-4">
    <h3>Recent Activity</h3>
    <div class="activity-feed">
      {{#for activity in analytics.recentActivity}}
      <div class="activity-item flex items-center gap-2">
        {{#switch activity.type}}
        {{#case "order"}}
        <span class="badge" style="background: #e8f5e9; color: #2e7d32;">Order</span>
        {{/case}}
        {{#case "review"}}
        <span class="badge" style="background: #fff3e0; color: #ef6c00;">Review</span>
        {{/case}}
        {{#case "signup"}}
        <span class="badge" style="background: #e3f2fd; color: #1565c0;">Signup</span>
        {{/case}}
        {{#case "refund"}}
        <span class="badge" style="background: #fce4ec; color: #c62828;">Refund</span>
        {{/case}}
        {{/switch}}
        <div>
          <p>{{activity.description}}</p>
          <p class="text-muted">{{activity.user}} &mdash; {{activity.timestamp}}</p>
        </div>
        {{#if activity.amount}}
        <span>{{currency}}{{activity.amount}}</span>
        {{/if}}
      </div>
      {{#empty}}
      <p class="text-muted">No recent activity.</p>
      {{/empty}}
      {{/for}}
    </div>
  </div>

  {{! --- Top Categories --- }}
  <div class="card">
    <h3>Top Categories</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Category</th>
          <th>Slug</th>
          <th>Parent</th>
          <th>Products</th>
        </tr>
      </thead>
      <tbody>
        {{#for cat in analytics.topCategories}}
        <tr>
          <td>{{@index}}</td>
          <td>{{cat.name}}</td>
          <td>{{cat.slug}}</td>
          {{#if cat.parentCategory}}
          <td>{{cat.parentCategory}}</td>
          {{#else}}
          <td class="text-muted">Root</td>
          {{/if}}
          <td>{{cat.productCount}}</td>
        </tr>
        {{/for}}
      </tbody>
    </table>
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: User Management                                      }}
{{! ============================================================ }}
<section id="users-management" class="mb-4">
  <h2>User Management</h2>

  {{! --- Current User Profile --- }}
  <div class="card mb-4">
    <h3>Current User Profile</h3>
    <div class="flex items-center gap-4">
      {{#if currentUser.avatar}}
      <img src="{{currentUser.avatar}}" alt="{{currentUser.username}}" class="avatar" width="64" height="64">
      {{#else}}
      <div class="avatar-placeholder" style="width: 64px; height: 64px;">
        {{currentUser.username}}
      </div>
      {{/if}}
      <div>
        <h4>{{currentUser.username}}</h4>
        <p>{{currentUser.email}}</p>
        <p>ID: {{currentUser.id}}</p>
        <p>Last Login: {{currentUser.lastLogin}}</p>

        {{! --- Role-specific info via union type access --- }}
        {{#if currentUser.isSuperAdmin}}
        <span class="badge" style="background: #7c3aed; color: #fff;">Super Admin</span>
        <p>Department: {{currentUser.department}}</p>
        <p>Access Level: {{currentUser.accessLevel}}</p>
        {{#else if currentUser.publishedCount}}
        <span class="badge" style="background: #059669; color: #fff;">Editor</span>
        <p>Published: {{currentUser.publishedCount}} | Drafts: {{currentUser.draftCount}}</p>
        <p>Bio: {{currentUser.bio}}</p>
        {{#else}}
        <span class="badge" style="background: #6b7280; color: #fff;">{{currentUser.role}}</span>
        {{/if}}
      </div>
    </div>

    {{! --- User Address (deeply nested) --- }}
    {{#with currentUser.address}}
    <div class="mt-4">
      <h4>Address</h4>
      <p>{{street}}</p>
      <p>{{city.name}}, {{zip}}</p>
      <p>Region: {{city.region.name}} ({{city.region.code}})</p>
      <p>Timezone: {{city.region.timezone}}</p>
      <p>Country: {{country.name}} ({{country.code}})</p>
      <p>Currency: {{country.currency.symbol}} ({{country.currency.code}}) - Rate: {{country.currency.exchangeRate}}</p>
      <p>City Population: {{city.population}}</p>
      {{#if isDefault}}
      <span class="badge text-success">Default Address</span>
      {{/if}}
    </div>
    {{#empty}}
    <div class="mt-4">
      <p class="text-muted">No address on file. Please add a shipping address.</p>
    </div>
    {{/empty}}
    {{/with}}

    {{! --- User Preferences (deeply nested) --- }}
    <div class="mt-4">
      <h4>Preferences</h4>
      {{#switch currentUser.preferences.theme}}
      {{#case "light"}}
      <span class="badge" style="background: #fef3c7;">Light Theme</span>
      {{/case}}
      {{#case "dark"}}
      <span class="badge" style="background: #1f2937; color: #fff;">Dark Theme</span>
      {{/case}}
      {{#case "auto"}}
      <span class="badge" style="background: #e0e7ff;">Auto Theme</span>
      {{/case}}
      {{/switch}}
      <p>Language: {{currentUser.preferences.language}}</p>
      <p>Items per page: {{currentUser.preferences.display.itemsPerPage}}</p>
      {{#if currentUser.preferences.display.compactMode}}
      <span class="badge">Compact Mode</span>
      {{/if}}
      {{#if currentUser.preferences.display.showSidebar}}
      <span class="badge">Sidebar Visible</span>
      {{/if}}

      <h5>Notification Settings</h5>
      <ul>
        {{#if currentUser.preferences.notifications.email}}
        <li>Email notifications: ON</li>
        {{#else}}
        <li>Email notifications: OFF</li>
        {{/if}}
        {{#if currentUser.preferences.notifications.push}}
        <li>Push notifications: ON</li>
        {{#else}}
        <li>Push notifications: OFF</li>
        {{/if}}
        {{#if currentUser.preferences.notifications.sms}}
        <li>SMS notifications: ON</li>
        {{#else}}
        <li>SMS notifications: OFF</li>
        {{/if}}
      </ul>
      {{#switch currentUser.preferences.notifications.frequency}}
      {{#case "instant"}}
      <p>Frequency: Instant delivery</p>
      {{/case}}
      {{#case "daily"}}
      <p>Frequency: Daily digest</p>
      {{/case}}
      {{#case "weekly"}}
      <p>Frequency: Weekly summary</p>
      {{/case}}
      {{/switch}}
    </div>
  </div>

  {{! --- Users Table --- }}
  <div class="card mb-4">
    <div class="flex justify-between items-center mb-4">
      <h3>All Users ({{users}})</h3>
      <div class="flex gap-2">
        {{#if showFilters}}
        <button class="btn btn-primary">Hide Filters</button>
        {{#else}}
        <button class="btn">Show Filters</button>
        {{/if}}
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>ID</th>
          <th>Username</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Last Login</th>
          <th>City</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#for user in users}}
        <tr>
          <td>{{@index}}</td>
          <td>{{user.id}}</td>
          <td>
            {{#if user.avatar}}
            <img src="{{user.avatar}}" alt="{{user.username}}" width="24" height="24">
            {{/if}}
            {{user.username}}
          </td>
          <td>{{user.email}}</td>
          <td>
            {{#switch user.role}}
            {{#case "admin"}}
            <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
            {{/case}}
            {{#case "editor"}}
            <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
            {{/case}}
            {{#case "viewer"}}
            <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
            {{/case}}
            {{/switch}}
          </td>
          <td>
            {{#if user.isActive}}
            <span class="badge text-success">Active</span>
            {{#else}}
            <span class="badge text-danger">Inactive</span>
            {{/if}}
          </td>
          <td>{{user.lastLogin}}</td>
          <td>
            {{#with user.address}}
            {{city.name}}, {{country.name}}
            {{#empty}}
            <span class="text-muted">N/A</span>
            {{/empty}}
            {{/with}}
          </td>
          <td>
            <button class="btn btn-primary">Edit</button>
            {{#if user.isActive}}
            <button class="btn btn-danger">Deactivate</button>
            {{#else}}
            <button class="btn btn-success">Activate</button>
            {{/if}}
          </td>
        </tr>

        {{! --- Expanded user details row --- }}
        <tr class="user-details-row">
          <td colspan="9">
            <div class="flex gap-4">
              <div>
                <strong>Preferences:</strong>
                <p>Theme: {{user.preferences.theme}}</p>
                <p>Language: {{user.preferences.language}}</p>
                <p>Notifications: {{#switch user.preferences.notifications.frequency}}
                {{#case "instant"}}Instant{{/case}}
                {{#case "daily"}}Daily{{/case}}
                {{#case "weekly"}}Weekly{{/case}}
                {{/switch}}</p>
              </div>
              <div>
                <strong>Display:</strong>
                <p>Items/Page: {{user.preferences.display.itemsPerPage}}</p>
                {{#if user.preferences.display.compactMode}}
                <p>Compact: Yes</p>
                {{#else}}
                <p>Compact: No</p>
                {{/if}}
              </div>
              {{#with user.address}}
              <div>
                <strong>Address:</strong>
                <p>{{street}}</p>
                <p>{{city.name}}, {{city.region.name}}</p>
                <p>{{country.name}} ({{country.currency.code}})</p>
              </div>
              {{/with}}
            </div>

            {{! --- Role-specific details in user row --- }}
            {{#if user.isSuperAdmin}}
            <div class="mt-4">
              <strong>Admin Details:</strong>
              <p>Department: {{user.department}}</p>
              <p>Access Level: {{user.accessLevel}}</p>
              <h5>Permissions:</h5>
              {{#for perm in user.permissions}}
              <span class="badge">{{perm}}</span>
              {{/for}}
            </div>
            {{#else if user.bio}}
            <div class="mt-4">
              <strong>Editor Details:</strong>
              <p>Bio: {{user.bio}}</p>
              <p>Published: {{user.publishedCount}} articles</p>
              <p>Drafts: {{user.draftCount}}</p>
              <h5>Assigned Categories:</h5>
              {{#for cat in user.assignedCategories}}
              <span class="badge">{{cat}}</span>
              {{/for}}
            </div>
            {{#else if user.favoriteCount}}
            <div class="mt-4">
              <strong>Viewer Details:</strong>
              <p>Registered: {{user.registeredAt}}</p>
              <p>Favorites: {{user.favoriteCount}}</p>
            </div>
            {{/if}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="9" class="text-muted" style="text-align: center; padding: 40px;">
            No users found. Try adjusting your filters.
          </td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Products Management                                   }}
{{! ============================================================ }}
<section id="products-management" class="mb-4">
  <h2>Products</h2>

  {{! --- Filters Bar --- }}
  {{#if showFilters}}
  <div class="card mb-4">
    <div class="flex gap-4 items-center">
      <div>
        <label>Search:</label>
        <input type="text" value="{{searchQuery}}" placeholder="Search products...">
      </div>
      <div>
        <label>Category:</label>
        {{#if selectedCategory}}
        <span class="badge">{{selectedCategory}}</span>
        {{#else}}
        <span class="text-muted">All Categories</span>
        {{/if}}
      </div>
      <div>
        <label>Sort:</label>
        <span>{{sortBy}} ({{sortDirection}})</span>
      </div>
      <div>
        <label>Per Page:</label>
        <span>{{itemsPerPage}}</span>
      </div>
    </div>
    <div class="mt-4">
      <p>Categories:</p>
      {{#for cat in categories}}
      <a href="#" class="badge">{{cat.name}} ({{cat.productCount}})</a>
      {{/for}}
    </div>
  </div>
  {{/if}}

  {{! --- Featured Product --- }}
  {{#with featuredProduct}}
  <div class="card mb-4" style="border: 2px solid #f59e0b; background: linear-gradient(135deg, #fffbeb, #fef3c7);">
    <div class="flex items-center gap-2 mb-4">
      <span class="badge" style="background: #f59e0b; color: #fff;">Featured</span>
      <h3>{{name}}</h3>
    </div>
    <div class="flex gap-4">
      {{#for img in images}}
      <div>
        {{#if img.isPrimary}}
        <img src="{{img.url}}" alt="{{img.alt}}" width="{{img.width}}" height="{{img.height}}" class="primary-image">
        {{#else}}
        <img src="{{img.url}}" alt="{{img.alt}}" width="120" height="120" class="thumbnail">
        {{/if}}
      </div>
      {{/for}}
    </div>
    <p>{{description}}</p>
    <p>{{shortDescription}}</p>
    <div class="flex items-center gap-4 mt-4">
      <span style="font-size: 1.5em; font-weight: bold;">{{../currency}}{{price}}</span>
      {{#if compareAtPrice}}
      <span style="text-decoration: line-through; color: #999;">{{../currency}}{{compareAtPrice}}</span>
      {{/if}}
      {{#if isOnSale}}
      <span class="badge text-danger">ON SALE</span>
      {{/if}}
    </div>
    <p>Rating: {{averageRating}}/5 ({{reviewCount}} reviews)</p>
    <p>Category: {{category.name}} ({{category.slug}})</p>
    <p>Weight: {{weight}}kg | Dimensions: {{dimensions.length}} x {{dimensions.width}} x {{dimensions.height}} {{dimensions.unit}}</p>
    <div class="mt-4">
      {{#for tag in tags}}
      <span class="badge">{{tag}}</span>
      {{/for}}
    </div>

    {{! --- Featured product variants --- }}
    <h4 class="mt-4">Variants</h4>
    {{#for variant in variants}}
    <div class="flex justify-between items-center" style="padding: 8px 0; border-bottom: 1px solid #eee;">
      <div>
        <strong>{{variant.name}}</strong>
        <span class="text-muted">(SKU: {{variant.sku}})</span>
      </div>
      <div class="flex items-center gap-2">
        <span>{{../../../currency}}{{variant.price}}</span>
        {{#if variant.compareAtPrice}}
        <span style="text-decoration: line-through; color: #999;">{{../../../currency}}{{variant.compareAtPrice}}</span>
        {{/if}}
        {{#if variant.inStock}}
        <span class="badge text-success">In Stock ({{variant.stockQuantity}})</span>
        {{#else}}
        <span class="badge text-danger">Out of Stock</span>
        {{/if}}
      </div>
    </div>
    <div>
      {{#for attr in variant.attributes}}
      <span class="badge">{{attr.name}}: {{attr.value}}</span>
      {{/for}}
    </div>
    {{#empty}}
    <p class="text-muted">No variants available.</p>
    {{/empty}}
    {{/for}}

    {{! --- Featured product reviews --- }}
    <h4 class="mt-4">Recent Reviews</h4>
    {{#for review in reviews}}
    <div class="card" style="margin: 8px 0;">
      <div class="flex justify-between">
        <strong>{{review.title}}</strong>
        <span>{{review.rating}}/5</span>
      </div>
      <p>{{review.body}}</p>
      <div class="flex justify-between text-muted">
        <span>{{review.author}} {{#if review.verified}}<span class="text-success">(Verified)</span>{{/if}}</span>
        <span>{{review.date}} | {{review.helpfulCount}} helpful</span>
      </div>
    </div>
    {{/for}}
  </div>
  {{#empty}}
  <div class="card mb-4">
    <p class="text-muted">No featured product currently set.</p>
  </div>
  {{/empty}}
  {{/with}}

  {{! --- Products Grid --- }}
  <div class="grid grid-3">
    {{#for product in products}}
    <div class="card">
      <div class="flex justify-between items-center mb-4">
        <h4>{{product.name}}</h4>
        {{#if product.isFeatured}}
        <span class="badge text-warning">Featured</span>
        {{/if}}
      </div>

      {{! Product images }}
      {{#for img in product.images}}
      {{#if img.isPrimary}}
      <img src="{{img.url}}" alt="{{img.alt}}" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px;">
      {{/if}}
      {{/for}}

      <p class="text-muted">{{product.shortDescription}}</p>
      <p>Category: {{product.category.name}}</p>

      <div class="flex items-center gap-2 mt-4">
        <span style="font-size: 1.3em; font-weight: bold;">{{currency}}{{product.price}}</span>
        {{#if product.compareAtPrice}}
        <span style="text-decoration: line-through; color: #999;">{{currency}}{{product.compareAtPrice}}</span>
        {{/if}}
      </div>

      <div class="flex items-center gap-2 mt-4">
        {{#if product.inStock}}
        <span class="badge text-success">In Stock</span>
        {{#else}}
        <span class="badge text-danger">Out of Stock</span>
        {{/if}}
        {{#if product.isOnSale}}
        <span class="badge text-danger">Sale</span>
        {{/if}}
      </div>

      <p class="mt-4">Rating: {{product.averageRating}}/5 ({{product.reviewCount}} reviews)</p>

      <div class="mt-4">
        {{#for tag in product.tags}}
        <span class="badge">{{tag}}</span>
        {{/for}}
      </div>

      {{! Product variants summary }}
      <div class="mt-4">
        <p class="text-muted">Variants:</p>
        {{#for variant in product.variants}}
        <div class="flex justify-between" style="padding: 4px 0;">
          <span>{{variant.name}}</span>
          <span>{{../../currency}}{{variant.price}}</span>
        </div>
        {{#empty}}
        <p class="text-muted">Single variant only</p>
        {{/empty}}
        {{/for}}
      </div>

      {{! First 2 reviews }}
      {{#for review in product.reviews}}
            <div class="mt-4" style="border-top: 1px solid #eee; padding-top: 8px;">
        <p><strong>{{review.title}}</strong> - {{review.rating}}/5</p>
        <p class="text-muted">{{review.author}}</p>
      </div>
      
      {{/for}}

      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">Edit</button>
        <button class="btn">View</button>
        {{#if !product.inStock}}
        <button class="btn btn-success">Restock</button>
        {{/if}}
      </div>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center; padding: 40px;">
        No products found. Try a different search query or category filter.
      </p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Pagination --- }}
  <div class="flex justify-between items-center mt-4">
    <p class="text-muted">Page {{currentPage}} of {{totalPages}}</p>
    <div class="flex gap-2">
      {{#if currentPage > 1}}
      <button class="btn">Previous</button>
      {{/if}}
      {{#if currentPage < totalPages}}
      <button class="btn btn-primary">Next</button>
      {{/if}}
    </div>
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Orders Management                                     }}
{{! ============================================================ }}
<section id="orders-management" class="mb-4">
  <h2>Orders</h2>

  {{! --- Orders Summary --- }}
  <div class="grid grid-3 mb-4">
    <div class="card">
      <p class="text-muted">Total Orders</p>
      <h3>{{analytics.orders.value}}</h3>
    </div>
    <div class="card">
      <p class="text-muted">Total Revenue</p>
      <h3>{{currency}}{{analytics.revenue.value}}</h3>
    </div>
    <div class="card">
      <p class="text-muted">Avg Order Value</p>
      <h3>{{currency}}{{analytics.currentPeriod.averageOrderValue}}</h3>
    </div>
  </div>

  {{! --- Orders Table --- }}
  <div class="card">
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Order #</th>
          <th>Customer</th>
          <th>Items</th>
          <th>Subtotal</th>
          <th>Tax</th>
          <th>Total</th>
          <th>Status</th>
          <th>Payment</th>
          <th>Shipping</th>
          <th>Date</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#for order in orders}}
        <tr>
          <td>
            {{@index}}
            <span class="badge text-success">Newest</span>
            <span class="badge text-muted">Oldest</span>
          </td>
          <td><strong>{{order.orderNumber}}</strong></td>
          <td>
            <div>
              <strong>{{order.customer.username}}</strong>
              <p class="text-muted">{{order.customer.email}}</p>
              {{#switch order.customer.role}}
              {{#case "admin"}}
              <span class="badge" style="background: #fef3c7;">Admin</span>
              {{/case}}
              {{#case "editor"}}
              <span class="badge" style="background: #d1fae5;">Editor</span>
              {{/case}}
              {{#case "viewer"}}
              <span class="badge" style="background: #e0e7ff;">Viewer</span>
              {{/case}}
              {{/switch}}
            </div>
          </td>
          <td>
            {{#for item in order.items}}
            <div class="flex justify-between" style="padding: 2px 0;">
              <span>{{item.product.name}}</span>
              <span>x{{item.quantity}} @ {{../../currency}}{{item.unitPrice}}</span>
            </div>
            {{#if item.discount > 0}}
            <span class="text-success">Discount: -{{../../currency}}{{item.discount}}</span>
            {{/if}}
            {{#if item.variant}}
            <span class="text-muted">({{item.variant.name}} - {{item.variant.sku}})</span>
            {{/if}}
            {{/for}}
          </td>
          <td>{{currency}}{{order.subtotal}}</td>
          <td>{{currency}}{{order.tax}}</td>
          <td><strong>{{currency}}{{order.total}}</strong></td>
          <td>
            {{#switch order.status}}
            {{#case "pending"}}
            <span class="badge" style="background: #fff3cd; color: #856404;">Pending</span>
            {{/case}}
            {{#case "processing"}}
            <span class="badge" style="background: #cce5ff; color: #004085;">Processing</span>
            {{/case}}
            {{#case "shipped"}}
            <span class="badge" style="background: #d1ecf1; color: #0c5460;">Shipped</span>
            {{/case}}
            {{#case "delivered"}}
            <span class="badge" style="background: #d4edda; color: #155724;">Delivered</span>
            {{/case}}
            {{#case "cancelled"}}
            <span class="badge" style="background: #f8d7da; color: #721c24;">Cancelled</span>
            {{/case}}
            {{#case "refunded"}}
            <span class="badge" style="background: #e2e3e5; color: #383d41;">Refunded</span>
            {{/case}}
            {{/switch}}
          </td>
          <td>
            {{#switch order.payment.method}}
            {{#case "credit_card"}}
            <span>Credit Card</span>
            {{/case}}
            {{#case "paypal"}}
            <span>PayPal</span>
            {{/case}}
            {{#case "bank_transfer"}}
            <span>Bank Transfer</span>
            {{/case}}
            {{#case "crypto"}}
            <span>Crypto</span>
            {{/case}}
            {{/switch}}
            <br>
            {{#switch order.payment.status}}
            {{#case "completed"}}
            <span class="text-success">Paid</span>
            {{/case}}
            {{#case "pending"}}
            <span class="text-warning">Pending</span>
            {{/case}}
            {{#case "failed"}}
            <span class="text-danger">Failed</span>
            {{/case}}
            {{#case "refunded"}}
            <span class="text-muted">Refunded</span>
            {{/case}}
            {{/switch}}
            <p class="text-muted">TX: {{order.payment.transactionId}}</p>
          </td>
          <td>
            <p>{{order.shipping.method}}</p>
            <p class="text-muted">{{order.shipping.carrier}}</p>
            {{#if order.shipping.trackingNumber}}
            <p>Track: {{order.shipping.trackingNumber}}</p>
            {{/if}}
            {{#if order.shipping.estimatedDelivery}}
            <p>ETA: {{order.shipping.estimatedDelivery}}</p>
            {{/if}}
            <p>Cost: {{currency}}{{order.shipping.cost}}</p>
          </td>
          <td>
            <p>{{order.createdAt}}</p>
            <p class="text-muted">Updated: {{order.updatedAt}}</p>
          </td>
          <td>
            <div class="flex gap-2">
              <button class="btn btn-primary">View</button>
              {{#switch order.status}}
              {{#case "pending"}}
              <button class="btn btn-success">Process</button>
              <button class="btn btn-danger">Cancel</button>
              {{/case}}
              {{#case "processing"}}
              <button class="btn btn-success">Ship</button>
              {{/case}}
              {{#case "shipped"}}
              <button class="btn btn-success">Deliver</button>
              {{/case}}
              {{#case "delivered"}}
              <button class="btn">Refund</button>
              {{/case}}
              {{/switch}}
            </div>
          </td>
        </tr>

        {{! --- Order detail expandable row --- }}
        <tr class="order-detail-row">
          <td colspan="12">
            <div class="grid grid-3 gap-4">
              <div>
                <h5>Customer Details</h5>
                <p>{{order.customer.username}} ({{order.customer.email}})</p>
                {{#with order.customer.address}}
                <p>{{street}}</p>
                <p>{{city.name}}, {{zip}}</p>
                <p>{{country.name}}</p>
                {{#empty}}
                <p class="text-muted">No address</p>
                {{/empty}}
                {{/with}}
              </div>
              <div>
                <h5>Shipping Address</h5>
                <p>{{order.shipping.address.street}}</p>
                <p>{{order.shipping.address.city.name}}, {{order.shipping.address.zip}}</p>
                <p>{{order.shipping.address.country.name}}</p>
                <p>Region: {{order.shipping.address.city.region.name}}</p>
              </div>
              <div>
                <h5>Payment Details</h5>
                <p>Amount: {{currency}}{{order.payment.amount}} {{order.payment.currency}}</p>
                <p>Transaction: {{order.payment.transactionId}}</p>
              </div>
            </div>
            {{#if order.notes}}
            <div class="mt-4">
              <h5>Order Notes</h5>
              <p>{{order.notes}}</p>
            </div>
            {{/if}}

            <h5 class="mt-4">Line Items Detail</h5>
            <table>
              <thead>
                <tr>
                  <th>Product</th>
                  <th>Category</th>
                  <th>Variant</th>
                  <th>Qty</th>
                  <th>Unit Price</th>
                  <th>Discount</th>
                  <th>Subtotal</th>
                </tr>
              </thead>
              <tbody>
                {{#for item in order.items}}
                <tr>
                  <td>
                    <strong>{{item.product.name}}</strong>
                    <p class="text-muted">{{item.product.shortDescription}}</p>
                    <p class="text-muted">Rating: {{item.product.averageRating}}/5</p>
                  </td>
                  <td>{{item.product.category.name}}</td>
                  <td>
                    {{#if item.variant}}
                    {{item.variant.name}} ({{item.variant.sku}})
                    {{#else}}
                    <span class="text-muted">Default</span>
                    {{/if}}
                  </td>
                  <td>{{item.quantity}}</td>
                  <td>{{../../../currency}}{{item.unitPrice}}</td>
                  <td>
                    {{#if item.discount > 0}}
                    <span class="text-success">-{{../../../currency}}{{item.discount}}</span>
                    {{#else}}
                    <span class="text-muted">-</span>
                    {{/if}}
                  </td>
                  <td>{{../../../currency}}{{item.unitPrice * item.quantity}}</td>
                </tr>
                {{/for}}
              </tbody>
            </table>
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="12" style="text-align: center; padding: 40px;">
            <p class="text-muted">No orders found.</p>
          </td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Recent Orders (Compact View)                          }}
{{! ============================================================ }}
<section id="recent-orders" class="mb-4">
  <h2>Recent Orders (Quick View)</h2>
  <div class="card">
    {{#for order in recentOrders}}
    <div class="flex justify-between items-center" style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div>
        <strong>#{{order.orderNumber}}</strong>
        <span class="text-muted"> - {{order.customer.username}}</span>
      </div>
      <div class="flex items-center gap-4">
        <span>{{currency}}{{order.total}}</span>
        {{#switch order.status}}
        {{#case "pending"}}
        <span class="badge" style="background: #fff3cd;">Pending</span>
        {{/case}}
        {{#case "processing"}}
        <span class="badge" style="background: #cce5ff;">Processing</span>
        {{/case}}
        {{#case "shipped"}}
        <span class="badge" style="background: #d1ecf1;">Shipped</span>
        {{/case}}
        {{#case "delivered"}}
        <span class="badge" style="background: #d4edda;">Delivered</span>
        {{/case}}
        {{#case "cancelled"}}
        <span class="badge" style="background: #f8d7da;">Cancelled</span>
        {{/case}}
        {{#case "refunded"}}
        <span class="badge" style="background: #e2e3e5;">Refunded</span>
        {{/case}}
        {{/switch}}
        <span class="text-muted">{{order.createdAt}}</span>
      </div>
    </div>
    {{! --- Order items inline --- }}
    <div style="padding: 4px 0 12px 20px;">
      {{#for item in order.items}}
      <span>{{item.product.name}} x{{item.quantity}}</span><span>, </span>
      {{/for}}
    </div>
    {{#empty}}
    <p class="text-muted" style="padding: 20px; text-align: center;">No recent orders.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Notifications                                         }}
{{! ============================================================ }}
<section id="notifications" class="mb-4">
  <h2>Notifications</h2>

  {{#for notif in notifications}}
  <div class="card mb-4" style="{{#if !notif.isRead}}border-left: 4px solid #4361ee;{{/if}}">
    <div class="flex justify-between items-center">
      <div class="flex items-center gap-2">
        {{#switch notif.kind}}
        {{#case "order"}}
        <span class="badge" style="background: #e8f5e9; color: #2e7d32;">Order</span>
        <div>
          <p><strong>New Order: {{notif.orderId}}</strong></p>
          <p>Customer: {{notif.customerName}}</p>
          <p>Total: {{currency}}{{notif.total}}</p>
        </div>
        {{/case}}
        {{#case "review"}}
        <span class="badge" style="background: #fff3e0; color: #ef6c00;">Review</span>
        <div>
          <p><strong>New Review for {{notif.productName}}</strong></p>
          <p>Rating: {{notif.rating}}/5 by {{notif.reviewerName}}</p>
        </div>
        {{/case}}
        {{#case "system"}}
        <span class="badge" style="background: #e3f2fd; color: #1565c0;">System</span>
        <div>
          <p><strong>{{notif.title}}</strong></p>
          <p>{{notif.message}}</p>
          {{#switch notif.severity}}
          {{#case "info"}}
          <span class="text-muted">Info</span>
          {{/case}}
          {{#case "warning"}}
          <span class="text-warning">Warning</span>
          {{/case}}
          {{#case "error"}}
          <span class="text-danger">Error</span>
          {{/case}}
          {{/switch}}
        </div>
        {{/case}}
        {{/switch}}
      </div>
      <div>
        <span class="text-muted">{{notif.timestamp}}</span>
        {{#if notif.isRead}}
        <span class="badge text-muted">Read</span>
        {{#else}}
        <span class="badge text-success">New</span>
        {{/if}}
      </div>
    </div>
  </div>
  {{#empty}}
  <div class="card">
    <p class="text-muted" style="text-align: center; padding: 20px;">No notifications.</p>
  </div>
  {{/empty}}
  {{/for}}
</section>


{{! ============================================================ }}
{{! SECTION: Settings Panel                                        }}
{{! ============================================================ }}
<section id="settings" class="mb-4">
  <h2>Settings</h2>

  {{#if settings.isDirty}}
  <div class="card mb-4" style="background: #fff3cd; border: 1px solid #ffc107;">
    <p><strong>You have unsaved changes.</strong></p>
    {{#if settings.lastSaved}}
    <p class="text-muted">Last saved: {{settings.lastSaved}}</p>
    {{#else}}
    <p class="text-muted">Never saved.</p>
    {{/if}}
    <button class="btn btn-primary">Save Changes</button>
  </div>
  {{/if}}

  {{! --- General Settings --- }}
  <div class="card mb-4">
    <h3>General Settings</h3>
    <div class="grid grid-2 gap-4">
      <div>
        <label>Site Name</label>
        <input type="text" value="{{settings.general.siteName}}" style="width: 100%;">
      </div>
      <div>
        <label>Site URL</label>
        <input type="text" value="{{settings.general.siteUrl}}" style="width: 100%;">
      </div>
      <div>
        <label>Admin Email</label>
        <input type="email" value="{{settings.general.adminEmail}}" style="width: 100%;">
      </div>
      <div>
        <label>Timezone</label>
        <input type="text" value="{{settings.general.timezone}}" style="width: 100%;">
      </div>
      <div>
        <label>Date Format</label>
        <input type="text" value="{{settings.general.dateFormat}}" style="width: 100%;">
      </div>
      <div>
        <label>Maintenance Mode</label>
        {{#if settings.general.maintenanceMode}}
        <span class="badge text-danger">ENABLED</span>
        <button class="btn btn-success">Disable</button>
        {{#else}}
        <span class="badge text-success">Disabled</span>
        <button class="btn btn-danger">Enable</button>
        {{/if}}
      </div>
    </div>
  </div>

  {{! --- Email Settings --- }}
  <div class="card mb-4">
    <h3>Email Settings</h3>
    <div class="grid grid-2 gap-4">
      <div>
        <label>SMTP Host</label>
        <input type="text" value="{{settings.email.smtpHost}}" style="width: 100%;">
      </div>
      <div>
        <label>SMTP Port</label>
        <input type="number" value="{{settings.email.smtpPort}}" style="width: 100%;">
      </div>
      <div>
        <label>From Name</label>
        <input type="text" value="{{settings.email.fromName}}" style="width: 100%;">
      </div>
      <div>
        <label>From Email</label>
        <input type="email" value="{{settings.email.fromEmail}}" style="width: 100%;">
      </div>
    </div>
    <div class="mt-4">
      {{#if settings.email.enableNotifications}}
      <span class="badge text-success">Notifications Enabled</span>
      {{#else}}
      <span class="badge text-muted">Notifications Disabled</span>
      {{/if}}
    </div>
  </div>

  {{! --- Payment Settings --- }}
  <div class="card mb-4">
    <h3>Payment Settings</h3>
    <div class="grid grid-2 gap-4">
      <div>
        <label>Default Currency</label>
        <input type="text" value="{{settings.payment.defaultCurrency}}" style="width: 100%;">
      </div>
      <div>
        <label>Tax Rate</label>
        <input type="number" value="{{settings.payment.taxRate}}" style="width: 100%;">
      </div>
    </div>

    {{#if settings.payment.freeShippingThreshold}}
    <p class="mt-4">Free shipping on orders over {{currency}}{{settings.payment.freeShippingThreshold}}</p>
    {{#else}}
    <p class="mt-4 text-muted">No free shipping threshold configured.</p>
    {{/if}}

    <h4 class="mt-4">Enabled Payment Methods</h4>
    {{#for method in settings.payment.enabledMethods}}
    <span class="badge">{{method}}</span>
    {{#empty}}
    <p class="text-muted">No payment methods enabled.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Optional Chaining Showcase                            }}
{{! ============================================================ }}
<section id="optional-chaining" class="mb-4">
  <h2>User Address Details (Optional Chaining)</h2>

  {{! Optional chaining through nullable address }}
  <div class="card mb-4">
    <h3>Current User Address</h3>
    <p>Street: {{currentUser.address?.street}}</p>
    <p>City: {{currentUser.address?.city.name}}</p>
    <p>Region: {{currentUser.address?.city.region.name}}</p>
    <p>Region Code: {{currentUser.address?.city.region.code}}</p>
    <p>Timezone: {{currentUser.address?.city.region.timezone}}</p>
    <p>Country: {{currentUser.address?.country.name}}</p>
    <p>Country Code: {{currentUser.address?.country.code}}</p>
    <p>Currency: {{currentUser.address?.country.currency.symbol}}</p>
    <p>Currency Code: {{currentUser.address?.country.currency.code}}</p>
    <p>Exchange Rate: {{currentUser.address?.country.currency.exchangeRate}}</p>
  </div>

  {{! Optional chaining on featured product }}
  <div class="card mb-4">
    <h3>Featured Product Details</h3>
    <p>Name: {{featuredProduct?.name}}</p>
    <p>Price: {{currency}}{{featuredProduct?.price}}</p>
    <p>Category: {{featuredProduct?.category.name}}</p>
    <p>Dimensions: {{featuredProduct?.dimensions.length}} x {{featuredProduct?.dimensions.width}} x {{featuredProduct?.dimensions.height}}</p>
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Arithmetic and Expressions                            }}
{{! ============================================================ }}
<section id="expressions" class="mb-4">
  <h2>Computed Values</h2>

  <div class="card mb-4">
    <h3>Page Info</h3>
    <p>Current page: {{currentPage}} of {{totalPages}}</p>
    {{#if currentPage > 1}}
    <p>Previous page available</p>
    {{/if}}
    {{#if currentPage < totalPages}}
    <p>Next page available</p>
    {{/if}}
    {{#if currentPage >= totalPages}}
    <p>This is the last page.</p>
    {{/if}}
  </div>

  {{! --- Order calculations --- }}
  <div class="card mb-4">
    <h3>Order Calculations</h3>
    {{#for order in orders}}
    <div style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      <p><strong>#{{order.orderNumber}}</strong></p>
      <p>Subtotal: {{currency}}{{order.subtotal}}</p>
      <p>Tax: {{currency}}{{order.tax}}</p>
      <p>Total: {{currency}}{{order.subtotal + order.tax}}</p>
      <p>Shipping: {{currency}}{{order.shipping.cost}}</p>
      <p>Grand Total: {{currency}}{{order.total + order.shipping.cost}}</p>

      {{#for item in order.items}}
      <div style="padding: 4px 16px;">
        <span>{{item.product.name}}: {{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        {{#if item.discount > 0}}
        <span class="text-success"> (save {{../../currency}}{{item.discount}})</span>
        {{/if}}
      </div>
      {{/for}}
    </div>
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Logical Expressions & Conditionals                    }}
{{! ============================================================ }}
<section id="logical-expressions" class="mb-4">
  <h2>Conditional Display Logic</h2>

  {{#for user in users}}
  <div class="card mb-4">
    <h4>{{user.username}}</h4>

    {{! Logical AND }}
    {{#if user.isActive && user.avatar}}
    <div class="flex items-center gap-2">
      <img src="{{user.avatar}}" width="32" height="32">
      <span class="text-success">Active user with avatar</span>
    </div>
    {{/if}}

    {{! Negation }}
    {{#if !user.isActive}}
    <p class="text-danger">This user account is deactivated.</p>
    {{/if}}

    {{! Comparison with loop meta }}
        <span class="badge text-success">First User</span>
    
        <span class="badge text-muted">Last User</span>
    
    <span class="text-muted">User {{@index}} of {{@length}}</span>
  </div>
  {{/for}}
</section>


{{! ============================================================ }}
{{! SECTION: Sales Department (Section 1)                }}
{{! ============================================================ }}
<section id="sales-1" class="mb-4">
  <h2>Sales - Section 1</h2>

  {{! --- Sales User Cards --- }}
  <div class="grid grid-3 mb-4">
    {{#for user in users}}
    <div class="card">
      <div class="flex items-center gap-4 mb-4">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" alt="{{user.username}}" width="48" height="48" style="border-radius: 50%;">
        {{#else}}
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          {{user.username}}
        </div>
        {{/if}}
        <div>
          <h4>{{user.username}}</h4>
          <p class="text-muted">{{user.email}}</p>
          <p class="text-muted">ID: {{user.id}}</p>
        </div>
      </div>

      {{! Role badge }}
      {{#switch user.role}}
      {{#case "admin"}}
      <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
      {{/case}}
      {{#case "editor"}}
      <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
      {{/case}}
      {{#case "viewer"}}
      <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
      {{/case}}
      {{/switch}}

      {{#if user.isActive}}
      <span class="badge text-success">Active</span>
      {{#else}}
      <span class="badge text-danger">Inactive</span>
      {{/if}}

      {{! Address info }}
      {{#with user.address}}
      <div class="mt-4">
        <p>{{street}}</p>
        <p>{{city.name}}, {{city.region.name}} {{zip}}</p>
        <p>{{country.name}} ({{country.currency.symbol}})</p>
        <p class="text-muted">TZ: {{city.region.timezone}}</p>
      </div>
      {{#empty}}
      <p class="text-muted mt-4">No address on file</p>
      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center;">No users in Sales department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Sales Product Listing --- }}
  <div class="card mb-4">
    <h3>Sales Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Sales Orders List --- }}
  <div class="card mb-4">
    <h3>Sales Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
          <span> - {{order.customer.username}} ({{order.customer.email}})</span>
        </div>
        <div class="flex items-center gap-2">
          {{#switch order.status}}
          {{#case "pending"}}
          <span class="badge" style="background: #fff3cd;">Pending</span>
          {{/case}}
          {{#case "processing"}}
          <span class="badge" style="background: #cce5ff;">Processing</span>
          {{/case}}
          {{#case "shipped"}}
          <span class="badge" style="background: #d1ecf1;">Shipped</span>
          {{/case}}
          {{#case "delivered"}}
          <span class="badge" style="background: #d4edda;">Delivered</span>
          {{/case}}
          {{#case "cancelled"}}
          <span class="badge" style="background: #f8d7da;">Cancelled</span>
          {{/case}}
          {{#case "refunded"}}
          <span class="badge" style="background: #e2e3e5;">Refunded</span>
          {{/case}}
          {{/switch}}
          <strong>{{currency}}{{order.total}}</strong>
        </div>
      </div>

      {{! Order items }}
      <div style="padding: 4px 0 0 20px;">
        {{#for item in order.items}}
        <div class="flex justify-between" style="padding: 2px 0;">
          <span>{{item.product.name}} ({{item.product.category.name}})</span>
          <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        </div>
        {{/for}}
      </div>

      {{! Shipping info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        <span>Ship: {{order.shipping.method}} via {{order.shipping.carrier}}</span>
        {{#if order.shipping.trackingNumber}}
        <span> | Track: {{order.shipping.trackingNumber}}</span>
        {{/if}}
        {{#if order.shipping.estimatedDelivery}}
        <span> | ETA: {{order.shipping.estimatedDelivery}}</span>
        {{/if}}
      </div>

      {{! Payment info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        {{#switch order.payment.method}}
        {{#case "credit_card"}}Credit Card{{/case}}
        {{#case "paypal"}}PayPal{{/case}}
        {{#case "bank_transfer"}}Bank Transfer{{/case}}
        {{#case "crypto"}}Crypto{{/case}}
        {{/switch}}
        -
        {{#switch order.payment.status}}
        {{#case "completed"}}<span class="text-success">Paid</span>{{/case}}
        {{#case "pending"}}<span class="text-warning">Pending</span>{{/case}}
        {{#case "failed"}}<span class="text-danger">Failed</span>{{/case}}
        {{#case "refunded"}}<span class="text-muted">Refunded</span>{{/case}}
        {{/switch}}
      </div>

      {{#if order.notes}}
      <div style="padding: 4px 0 0 20px;">
        <em>Note: {{order.notes}}</em>
      </div>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders in this section.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Sales Notifications --- }}
  <div class="card">
    <h3>Sales Notifications</h3>
    {{#for notif in notifications}}
    <div class="flex items-center gap-2" style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      {{#switch notif.kind}}
      {{#case "order"}}
      <span class="badge" style="background: #e8f5e9;">Order</span>
      <span>Order {{notif.orderId}} from {{notif.customerName}} - {{currency}}{{notif.total}}</span>
      {{/case}}
      {{#case "review"}}
      <span class="badge" style="background: #fff3e0;">Review</span>
      <span>{{notif.productName}} rated {{notif.rating}}/5 by {{notif.reviewerName}}</span>
      {{/case}}
      {{#case "system"}}
      <span class="badge" style="background: #e3f2fd;">System</span>
      <span>{{notif.title}}: {{notif.message}}</span>
      {{/case}}
      {{/switch}}
      <span class="text-muted">{{notif.timestamp}}</span>
      {{#if !notif.isRead}}
      <span class="badge text-success">New</span>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No notifications.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Marketing Department (Section 2)                }}
{{! ============================================================ }}
<section id="marketing-2" class="mb-4">
  <h2>Marketing - Section 2</h2>

  {{! --- Marketing User Cards --- }}
  <div class="grid grid-3 mb-4">
    {{#for user in users}}
    <div class="card">
      <div class="flex items-center gap-4 mb-4">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" alt="{{user.username}}" width="48" height="48" style="border-radius: 50%;">
        {{#else}}
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          {{user.username}}
        </div>
        {{/if}}
        <div>
          <h4>{{user.username}}</h4>
          <p class="text-muted">{{user.email}}</p>
          <p class="text-muted">ID: {{user.id}}</p>
        </div>
      </div>

      {{! Role badge }}
      {{#switch user.role}}
      {{#case "admin"}}
      <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
      {{/case}}
      {{#case "editor"}}
      <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
      {{/case}}
      {{#case "viewer"}}
      <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
      {{/case}}
      {{/switch}}

      {{#if user.isActive}}
      <span class="badge text-success">Active</span>
      {{#else}}
      <span class="badge text-danger">Inactive</span>
      {{/if}}

      {{! Address info }}
      {{#with user.address}}
      <div class="mt-4">
        <p>{{street}}</p>
        <p>{{city.name}}, {{city.region.name}} {{zip}}</p>
        <p>{{country.name}} ({{country.currency.symbol}})</p>
        <p class="text-muted">TZ: {{city.region.timezone}}</p>
      </div>
      {{#empty}}
      <p class="text-muted mt-4">No address on file</p>
      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center;">No users in Marketing department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Marketing Product Listing --- }}
  <div class="card mb-4">
    <h3>Marketing Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Marketing Orders List --- }}
  <div class="card mb-4">
    <h3>Marketing Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
          <span> - {{order.customer.username}} ({{order.customer.email}})</span>
        </div>
        <div class="flex items-center gap-2">
          {{#switch order.status}}
          {{#case "pending"}}
          <span class="badge" style="background: #fff3cd;">Pending</span>
          {{/case}}
          {{#case "processing"}}
          <span class="badge" style="background: #cce5ff;">Processing</span>
          {{/case}}
          {{#case "shipped"}}
          <span class="badge" style="background: #d1ecf1;">Shipped</span>
          {{/case}}
          {{#case "delivered"}}
          <span class="badge" style="background: #d4edda;">Delivered</span>
          {{/case}}
          {{#case "cancelled"}}
          <span class="badge" style="background: #f8d7da;">Cancelled</span>
          {{/case}}
          {{#case "refunded"}}
          <span class="badge" style="background: #e2e3e5;">Refunded</span>
          {{/case}}
          {{/switch}}
          <strong>{{currency}}{{order.total}}</strong>
        </div>
      </div>

      {{! Order items }}
      <div style="padding: 4px 0 0 20px;">
        {{#for item in order.items}}
        <div class="flex justify-between" style="padding: 2px 0;">
          <span>{{item.product.name}} ({{item.product.category.name}})</span>
          <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        </div>
        {{/for}}
      </div>

      {{! Shipping info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        <span>Ship: {{order.shipping.method}} via {{order.shipping.carrier}}</span>
        {{#if order.shipping.trackingNumber}}
        <span> | Track: {{order.shipping.trackingNumber}}</span>
        {{/if}}
        {{#if order.shipping.estimatedDelivery}}
        <span> | ETA: {{order.shipping.estimatedDelivery}}</span>
        {{/if}}
      </div>

      {{! Payment info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        {{#switch order.payment.method}}
        {{#case "credit_card"}}Credit Card{{/case}}
        {{#case "paypal"}}PayPal{{/case}}
        {{#case "bank_transfer"}}Bank Transfer{{/case}}
        {{#case "crypto"}}Crypto{{/case}}
        {{/switch}}
        -
        {{#switch order.payment.status}}
        {{#case "completed"}}<span class="text-success">Paid</span>{{/case}}
        {{#case "pending"}}<span class="text-warning">Pending</span>{{/case}}
        {{#case "failed"}}<span class="text-danger">Failed</span>{{/case}}
        {{#case "refunded"}}<span class="text-muted">Refunded</span>{{/case}}
        {{/switch}}
      </div>

      {{#if order.notes}}
      <div style="padding: 4px 0 0 20px;">
        <em>Note: {{order.notes}}</em>
      </div>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders in this section.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Marketing Notifications --- }}
  <div class="card">
    <h3>Marketing Notifications</h3>
    {{#for notif in notifications}}
    <div class="flex items-center gap-2" style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      {{#switch notif.kind}}
      {{#case "order"}}
      <span class="badge" style="background: #e8f5e9;">Order</span>
      <span>Order {{notif.orderId}} from {{notif.customerName}} - {{currency}}{{notif.total}}</span>
      {{/case}}
      {{#case "review"}}
      <span class="badge" style="background: #fff3e0;">Review</span>
      <span>{{notif.productName}} rated {{notif.rating}}/5 by {{notif.reviewerName}}</span>
      {{/case}}
      {{#case "system"}}
      <span class="badge" style="background: #e3f2fd;">System</span>
      <span>{{notif.title}}: {{notif.message}}</span>
      {{/case}}
      {{/switch}}
      <span class="text-muted">{{notif.timestamp}}</span>
      {{#if !notif.isRead}}
      <span class="badge text-success">New</span>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No notifications.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Engineering Department (Section 3)                }}
{{! ============================================================ }}
<section id="engineering-3" class="mb-4">
  <h2>Engineering - Section 3</h2>

  {{! --- Engineering User Cards --- }}
  <div class="grid grid-3 mb-4">
    {{#for user in users}}
    <div class="card">
      <div class="flex items-center gap-4 mb-4">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" alt="{{user.username}}" width="48" height="48" style="border-radius: 50%;">
        {{#else}}
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          {{user.username}}
        </div>
        {{/if}}
        <div>
          <h4>{{user.username}}</h4>
          <p class="text-muted">{{user.email}}</p>
          <p class="text-muted">ID: {{user.id}}</p>
        </div>
      </div>

      {{! Role badge }}
      {{#switch user.role}}
      {{#case "admin"}}
      <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
      {{/case}}
      {{#case "editor"}}
      <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
      {{/case}}
      {{#case "viewer"}}
      <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
      {{/case}}
      {{/switch}}

      {{#if user.isActive}}
      <span class="badge text-success">Active</span>
      {{#else}}
      <span class="badge text-danger">Inactive</span>
      {{/if}}

      {{! Address info }}
      {{#with user.address}}
      <div class="mt-4">
        <p>{{street}}</p>
        <p>{{city.name}}, {{city.region.name}} {{zip}}</p>
        <p>{{country.name}} ({{country.currency.symbol}})</p>
        <p class="text-muted">TZ: {{city.region.timezone}}</p>
      </div>
      {{#empty}}
      <p class="text-muted mt-4">No address on file</p>
      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center;">No users in Engineering department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Engineering Product Listing --- }}
  <div class="card mb-4">
    <h3>Engineering Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Engineering Orders List --- }}
  <div class="card mb-4">
    <h3>Engineering Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
          <span> - {{order.customer.username}} ({{order.customer.email}})</span>
        </div>
        <div class="flex items-center gap-2">
          {{#switch order.status}}
          {{#case "pending"}}
          <span class="badge" style="background: #fff3cd;">Pending</span>
          {{/case}}
          {{#case "processing"}}
          <span class="badge" style="background: #cce5ff;">Processing</span>
          {{/case}}
          {{#case "shipped"}}
          <span class="badge" style="background: #d1ecf1;">Shipped</span>
          {{/case}}
          {{#case "delivered"}}
          <span class="badge" style="background: #d4edda;">Delivered</span>
          {{/case}}
          {{#case "cancelled"}}
          <span class="badge" style="background: #f8d7da;">Cancelled</span>
          {{/case}}
          {{#case "refunded"}}
          <span class="badge" style="background: #e2e3e5;">Refunded</span>
          {{/case}}
          {{/switch}}
          <strong>{{currency}}{{order.total}}</strong>
        </div>
      </div>

      {{! Order items }}
      <div style="padding: 4px 0 0 20px;">
        {{#for item in order.items}}
        <div class="flex justify-between" style="padding: 2px 0;">
          <span>{{item.product.name}} ({{item.product.category.name}})</span>
          <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        </div>
        {{/for}}
      </div>

      {{! Shipping info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        <span>Ship: {{order.shipping.method}} via {{order.shipping.carrier}}</span>
        {{#if order.shipping.trackingNumber}}
        <span> | Track: {{order.shipping.trackingNumber}}</span>
        {{/if}}
        {{#if order.shipping.estimatedDelivery}}
        <span> | ETA: {{order.shipping.estimatedDelivery}}</span>
        {{/if}}
      </div>

      {{! Payment info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        {{#switch order.payment.method}}
        {{#case "credit_card"}}Credit Card{{/case}}
        {{#case "paypal"}}PayPal{{/case}}
        {{#case "bank_transfer"}}Bank Transfer{{/case}}
        {{#case "crypto"}}Crypto{{/case}}
        {{/switch}}
        -
        {{#switch order.payment.status}}
        {{#case "completed"}}<span class="text-success">Paid</span>{{/case}}
        {{#case "pending"}}<span class="text-warning">Pending</span>{{/case}}
        {{#case "failed"}}<span class="text-danger">Failed</span>{{/case}}
        {{#case "refunded"}}<span class="text-muted">Refunded</span>{{/case}}
        {{/switch}}
      </div>

      {{#if order.notes}}
      <div style="padding: 4px 0 0 20px;">
        <em>Note: {{order.notes}}</em>
      </div>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders in this section.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Engineering Notifications --- }}
  <div class="card">
    <h3>Engineering Notifications</h3>
    {{#for notif in notifications}}
    <div class="flex items-center gap-2" style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      {{#switch notif.kind}}
      {{#case "order"}}
      <span class="badge" style="background: #e8f5e9;">Order</span>
      <span>Order {{notif.orderId}} from {{notif.customerName}} - {{currency}}{{notif.total}}</span>
      {{/case}}
      {{#case "review"}}
      <span class="badge" style="background: #fff3e0;">Review</span>
      <span>{{notif.productName}} rated {{notif.rating}}/5 by {{notif.reviewerName}}</span>
      {{/case}}
      {{#case "system"}}
      <span class="badge" style="background: #e3f2fd;">System</span>
      <span>{{notif.title}}: {{notif.message}}</span>
      {{/case}}
      {{/switch}}
      <span class="text-muted">{{notif.timestamp}}</span>
      {{#if !notif.isRead}}
      <span class="badge text-success">New</span>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No notifications.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Support Department (Section 4)                }}
