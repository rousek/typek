      <p class="text-muted" style="text-align: center;">No users in Operations department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Operations Product Listing --- }}
  <div class="card mb-4">
    <h3>Operations Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
