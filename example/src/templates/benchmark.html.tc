      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
