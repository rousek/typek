{{! SECTION: Return Analysis Report (Report 8)                     }}
{{! ============================================================ }}
<section id="report-return-analysis-8" class="mb-4">
  <h2>Return Analysis Report #8</h2>

  {{! --- Summary Cards --- }}
  <div class="grid grid-4 mb-4">
    {{#for card in dashboardCards}}
    <div class="card" style="border-top: 3px solid {{card.color}};">
      <p class="text-muted">{{card.title}}</p>
      <h3>{{card.value}}</h3>
      <p>{{card.subtitle}}</p>
      {{#switch card.trend}}
      {{#case "up"}}
      <span class="text-success">+{{card.changePercent}}%</span>
      {{/case}}
      {{#case "down"}}
      <span class="text-danger">-{{card.changePercent}}%</span>
      {{/case}}
      {{#default}}
      <span class="text-muted">No change</span>
      {{/default}}
      {{/switch}}
    </div>
    {{/for}}
  </div>

  {{! --- Products Performance Table --- }}
  <div class="card mb-4">
    <h3>Return Analysis Product Performance</h3>
    <table>
      <thead>
        <tr>
          <th>Rank</th>
          <th>Product</th>
          <th>Price</th>
          <th>Category</th>
          <th>Rating</th>
          <th>Reviews</th>
          <th>Status</th>
          <th>Featured</th>
          <th>Sale</th>
          <th>Weight</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>
            {{@index}}
            <span class="text-success"> (Top)</span>
            <span class="text-muted"> (Bottom)</span>
          </td>
          <td>
            <div>
              <strong>{{product.name}}</strong>
              <p class="text-muted">{{product.slug}}</p>
              <p>{{product.shortDescription}}</p>
            </div>
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
          </td>
          <td>
            {{product.category.name}}
            <br><span class="text-muted">{{product.category.slug}}</span>
            {{#if product.category.parentCategory}}
            <br><span class="text-muted">Parent: {{product.category.parentCategory}}</span>
            {{/if}}
            <br><span class="text-muted">{{product.category.productCount}} products</span>
          </td>
          <td>{{product.averageRating}}/5</td>
          <td>{{product.reviewCount}}</td>
          <td>
            {{#if product.inStock}}
            <span class="badge text-success">Available</span>
            {{#else}}
            <span class="badge text-danger">Unavailable</span>
            {{/if}}
          </td>
          <td>{{#if product.isFeatured}}<span class="text-warning">Yes</span>{{#else}}<span class="text-muted">No</span>{{/if}}</td>
          <td>{{#if product.isOnSale}}<span class="text-danger">Yes</span>{{#else}}<span class="text-muted">No</span>{{/if}}</td>
          <td>{{product.weight}}kg<br>{{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}</td>
        </tr>

        {{! Product images }}
        <tr>
          <td colspan="10" style="padding-left: 40px;">
            <div class="flex gap-2">
              {{#for img in product.images}}
              <div style="text-align: center;">
                <img src="{{img.url}}" alt="{{img.alt}}" width="80" height="80" style="border-radius: 4px;">
                <p class="text-muted">{{img.width}}x{{img.height}}</p>
                {{#if img.isPrimary}}
                <span class="badge text-success">Primary</span>
                {{/if}}
              </div>
              {{/for}}
            </div>
          </td>
        </tr>

        {{! Variants detail }}
        <tr>
          <td colspan="10" style="padding-left: 40px;">
            <p><strong>Variants:</strong></p>
            {{#for variant in product.variants}}
            <div class="flex justify-between items-center" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div>
                <span>{{variant.name}}</span>
                <span class="text-muted">({{variant.sku}})</span>
              </div>
              <div class="flex items-center gap-2">
                <span>{{../../currency}}{{variant.price}}</span>
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">{{variant.stockQuantity}} in stock</span>
                {{#else}}
                <span class="text-danger">Out of stock</span>
                {{/if}}
              </div>
            </div>
            {{#for attr in variant.attributes}}
            <span class="badge" style="margin-left: 16px;">{{attr.name}}: {{attr.value}}</span>
            {{/for}}
            {{#empty}}
            <p class="text-muted">No variants defined</p>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr><td colspan="10" class="text-muted" style="text-align: center;">No data</td></tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Order Analysis --- }}
  <div class="card mb-4">
    <h3>Return Analysis Order Analysis</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between">
        <div>
          <strong>#{{order.orderNumber}}</strong> - {{order.customer.username}}
          <span class="text-muted">({{order.customer.email}})</span>
        </div>
        <div>
          {{#switch order.status}}
          {{#case "pending"}}<span class="badge" style="background: #fff3cd;">Pending</span>{{/case}}
          {{#case "processing"}}<span class="badge" style="background: #cce5ff;">Processing</span>{{/case}}
          {{#case "shipped"}}<span class="badge" style="background: #d1ecf1;">Shipped</span>{{/case}}
          {{#case "delivered"}}<span class="badge" style="background: #d4edda;">Delivered</span>{{/case}}
          {{#case "cancelled"}}<span class="badge" style="background: #f8d7da;">Cancelled</span>{{/case}}
          {{#case "refunded"}}<span class="badge" style="background: #e2e3e5;">Refunded</span>{{/case}}
          {{/switch}}
        </div>
      </div>

      <div class="grid grid-3 gap-4 mt-4" style="padding-left: 20px;">
        <div>
          <p class="text-muted">Financial</p>
          <p>Subtotal: {{currency}}{{order.subtotal}}</p>
          <p>Tax: {{currency}}{{order.tax}}</p>
          <p>Total: {{currency}}{{order.total}}</p>
          <p>Computed: {{currency}}{{order.subtotal + order.tax}}</p>
        </div>
        <div>
          <p class="text-muted">Shipping</p>
          <p>{{order.shipping.method}} ({{order.shipping.carrier}})</p>
          <p>Cost: {{currency}}{{order.shipping.cost}}</p>
          {{#if order.shipping.trackingNumber}}
          <p>Track: {{order.shipping.trackingNumber}}</p>
          {{/if}}
          {{#if order.shipping.estimatedDelivery}}
          <p>ETA: {{order.shipping.estimatedDelivery}}</p>
          {{/if}}
          <p>To: {{order.shipping.address.city.name}}, {{order.shipping.address.country.name}}</p>
        </div>
        <div>
          <p class="text-muted">Payment</p>
          {{#switch order.payment.method}}
          {{#case "credit_card"}}<p>Credit Card</p>{{/case}}
          {{#case "paypal"}}<p>PayPal</p>{{/case}}
          {{#case "bank_transfer"}}<p>Bank Transfer</p>{{/case}}
          {{#case "crypto"}}<p>Crypto</p>{{/case}}
          {{/switch}}
          <p>Amount: {{currency}}{{order.payment.amount}} {{order.payment.currency}}</p>
          <p>TX: {{order.payment.transactionId}}</p>
        </div>
      </div>

      {{! Line items }}
      {{#for item in order.items}}
      <div style="padding: 4px 20px;" class="flex justify-between">
        <span>{{item.product.name}} ({{item.product.category.name}})</span>
        <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} {{#if item.discount > 0}}<span class="text-success">-{{../../currency}}{{item.discount}}</span>{{/if}}</span>
      </div>
      {{/for}}

      {{#if order.notes}}
      <p style="padding: 4px 20px;" class="text-muted"><em>{{order.notes}}</em></p>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders for this report.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Activity Feed --- }}
  <div class="card">
    <h3>Return Analysis Activity</h3>
    {{#for activity in analytics.recentActivity}}
    <div class="flex items-center gap-2" style="padding: 6px 0; border-bottom: 1px solid #f5f5f5;">
      {{#switch activity.type}}
      {{#case "order"}}<span class="badge" style="background: #e8f5e9;">Order</span>{{/case}}
      {{#case "review"}}<span class="badge" style="background: #fff3e0;">Review</span>{{/case}}
      {{#case "signup"}}<span class="badge" style="background: #e3f2fd;">Signup</span>{{/case}}
      {{#case "refund"}}<span class="badge" style="background: #fce4ec;">Refund</span>{{/case}}
      {{/switch}}
      <span>{{activity.description}}</span>
      <span class="text-muted">{{activity.user}} - {{activity.timestamp}}</span>
      {{#if activity.amount}}
      <span>{{currency}}{{activity.amount}}</span>
      {{/if}}
    </div>
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Marketing ROI Report (Report 9)                     }}
