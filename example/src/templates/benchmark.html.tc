      <p class="text-muted" style="text-align: center;">No users in Product department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Product Product Listing --- }}
  <div class="card mb-4">
    <h3>Product Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Product Orders List --- }}
  <div class="card mb-4">
    <h3>Product Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
          <span> - {{order.customer.username}} ({{order.customer.email}})</span>
        </div>
        <div class="flex items-center gap-2">
          {{#switch order.status}}
          {{#case "pending"}}
          <span class="badge" style="background: #fff3cd;">Pending</span>
          {{/case}}
          {{#case "processing"}}
          <span class="badge" style="background: #cce5ff;">Processing</span>
          {{/case}}
          {{#case "shipped"}}
          <span class="badge" style="background: #d1ecf1;">Shipped</span>
          {{/case}}
          {{#case "delivered"}}
          <span class="badge" style="background: #d4edda;">Delivered</span>
          {{/case}}
          {{#case "cancelled"}}
          <span class="badge" style="background: #f8d7da;">Cancelled</span>
          {{/case}}
          {{#case "refunded"}}
          <span class="badge" style="background: #e2e3e5;">Refunded</span>
          {{/case}}
          {{/switch}}
          <strong>{{currency}}{{order.total}}</strong>
        </div>
      </div>

      {{! Order items }}
      <div style="padding: 4px 0 0 20px;">
        {{#for item in order.items}}
        <div class="flex justify-between" style="padding: 2px 0;">
          <span>{{item.product.name}} ({{item.product.category.name}})</span>
          <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        </div>
        {{/for}}
      </div>

      {{! Shipping info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        <span>Ship: {{order.shipping.method}} via {{order.shipping.carrier}}</span>
        {{#if order.shipping.trackingNumber}}
        <span> | Track: {{order.shipping.trackingNumber}}</span>
        {{/if}}
        {{#if order.shipping.estimatedDelivery}}
        <span> | ETA: {{order.shipping.estimatedDelivery}}</span>
        {{/if}}
      </div>

      {{! Payment info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        {{#switch order.payment.method}}
        {{#case "credit_card"}}Credit Card{{/case}}
        {{#case "paypal"}}PayPal{{/case}}
        {{#case "bank_transfer"}}Bank Transfer{{/case}}
        {{#case "crypto"}}Crypto{{/case}}
        {{/switch}}
        -
        {{#switch order.payment.status}}
        {{#case "completed"}}<span class="text-success">Paid</span>{{/case}}
        {{#case "pending"}}<span class="text-warning">Pending</span>{{/case}}
        {{#case "failed"}}<span class="text-danger">Failed</span>{{/case}}
        {{#case "refunded"}}<span class="text-muted">Refunded</span>{{/case}}
        {{/switch}}
      </div>

      {{#if order.notes}}
      <div style="padding: 4px 0 0 20px;">
        <em>Note: {{order.notes}}</em>
      </div>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders in this section.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Product Notifications --- }}
  <div class="card">
    <h3>Product Notifications</h3>
    {{#for notif in notifications}}
    <div class="flex items-center gap-2" style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      {{#switch notif.kind}}
      {{#case "order"}}
      <span class="badge" style="background: #e8f5e9;">Order</span>
      <span>Order {{notif.orderId}} from {{notif.customerName}} - {{currency}}{{notif.total}}</span>
      {{/case}}
      {{#case "review"}}
      <span class="badge" style="background: #fff3e0;">Review</span>
      <span>{{notif.productName}} rated {{notif.rating}}/5 by {{notif.reviewerName}}</span>
      {{/case}}
      {{#case "system"}}
      <span class="badge" style="background: #e3f2fd;">System</span>
      <span>{{notif.title}}: {{notif.message}}</span>
      {{/case}}
      {{/switch}}
      <span class="text-muted">{{notif.timestamp}}</span>
      {{#if !notif.isRead}}
      <span class="badge text-success">New</span>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No notifications.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Design Department (Section 9)                }}
{{! ============================================================ }}
<section id="design-9" class="mb-4">
  <h2>Design - Section 9</h2>

  {{! --- Design User Cards --- }}
  <div class="grid grid-3 mb-4">
    {{#for user in users}}
    <div class="card">
      <div class="flex items-center gap-4 mb-4">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" alt="{{user.username}}" width="48" height="48" style="border-radius: 50%;">
        {{#else}}
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          {{user.username}}
        </div>
        {{/if}}
        <div>
          <h4>{{user.username}}</h4>
          <p class="text-muted">{{user.email}}</p>
          <p class="text-muted">ID: {{user.id}}</p>
        </div>
      </div>

      {{! Role badge }}
      {{#switch user.role}}
      {{#case "admin"}}
      <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
      {{/case}}
      {{#case "editor"}}
      <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
      {{/case}}
      {{#case "viewer"}}
      <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
      {{/case}}
      {{/switch}}

      {{#if user.isActive}}
      <span class="badge text-success">Active</span>
      {{#else}}
      <span class="badge text-danger">Inactive</span>
      {{/if}}

      {{! Address info }}
      {{#with user.address}}
      <div class="mt-4">
        <p>{{street}}</p>
        <p>{{city.name}}, {{city.region.name}} {{zip}}</p>
        <p>{{country.name}} ({{country.currency.symbol}})</p>
        <p class="text-muted">TZ: {{city.region.timezone}}</p>
      </div>
      {{#empty}}
      <p class="text-muted mt-4">No address on file</p>
      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center;">No users in Design department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Design Product Listing --- }}
  <div class="card mb-4">
    <h3>Design Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Design Orders List --- }}
  <div class="card mb-4">
    <h3>Design Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
          <span> - {{order.customer.username}} ({{order.customer.email}})</span>
        </div>
        <div class="flex items-center gap-2">
          {{#switch order.status}}
          {{#case "pending"}}
          <span class="badge" style="background: #fff3cd;">Pending</span>
          {{/case}}
          {{#case "processing"}}
          <span class="badge" style="background: #cce5ff;">Processing</span>
          {{/case}}
          {{#case "shipped"}}
          <span class="badge" style="background: #d1ecf1;">Shipped</span>
          {{/case}}
          {{#case "delivered"}}
          <span class="badge" style="background: #d4edda;">Delivered</span>
          {{/case}}
          {{#case "cancelled"}}
          <span class="badge" style="background: #f8d7da;">Cancelled</span>
          {{/case}}
          {{#case "refunded"}}
          <span class="badge" style="background: #e2e3e5;">Refunded</span>
          {{/case}}
          {{/switch}}
          <strong>{{currency}}{{order.total}}</strong>
        </div>
      </div>

      {{! Order items }}
      <div style="padding: 4px 0 0 20px;">
        {{#for item in order.items}}
        <div class="flex justify-between" style="padding: 2px 0;">
          <span>{{item.product.name}} ({{item.product.category.name}})</span>
          <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        </div>
        {{/for}}
      </div>

      {{! Shipping info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        <span>Ship: {{order.shipping.method}} via {{order.shipping.carrier}}</span>
        {{#if order.shipping.trackingNumber}}
        <span> | Track: {{order.shipping.trackingNumber}}</span>
        {{/if}}
        {{#if order.shipping.estimatedDelivery}}
        <span> | ETA: {{order.shipping.estimatedDelivery}}</span>
        {{/if}}
      </div>

      {{! Payment info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        {{#switch order.payment.method}}
        {{#case "credit_card"}}Credit Card{{/case}}
        {{#case "paypal"}}PayPal{{/case}}
        {{#case "bank_transfer"}}Bank Transfer{{/case}}
        {{#case "crypto"}}Crypto{{/case}}
        {{/switch}}
        -
        {{#switch order.payment.status}}
        {{#case "completed"}}<span class="text-success">Paid</span>{{/case}}
        {{#case "pending"}}<span class="text-warning">Pending</span>{{/case}}
        {{#case "failed"}}<span class="text-danger">Failed</span>{{/case}}
        {{#case "refunded"}}<span class="text-muted">Refunded</span>{{/case}}
        {{/switch}}
      </div>

      {{#if order.notes}}
      <div style="padding: 4px 0 0 20px;">
        <em>Note: {{order.notes}}</em>
      </div>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders in this section.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Design Notifications --- }}
  <div class="card">
    <h3>Design Notifications</h3>
    {{#for notif in notifications}}
    <div class="flex items-center gap-2" style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      {{#switch notif.kind}}
      {{#case "order"}}
      <span class="badge" style="background: #e8f5e9;">Order</span>
      <span>Order {{notif.orderId}} from {{notif.customerName}} - {{currency}}{{notif.total}}</span>
      {{/case}}
      {{#case "review"}}
      <span class="badge" style="background: #fff3e0;">Review</span>
      <span>{{notif.productName}} rated {{notif.rating}}/5 by {{notif.reviewerName}}</span>
      {{/case}}
      {{#case "system"}}
      <span class="badge" style="background: #e3f2fd;">System</span>
      <span>{{notif.title}}: {{notif.message}}</span>
      {{/case}}
      {{/switch}}
      <span class="text-muted">{{notif.timestamp}}</span>
      {{#if !notif.isRead}}
      <span class="badge text-success">New</span>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No notifications.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Quality Assurance Department (Section 10)                }}
{{! ============================================================ }}
<section id="quality-assurance-10" class="mb-4">
  <h2>Quality Assurance - Section 10</h2>

  {{! --- Quality Assurance User Cards --- }}
  <div class="grid grid-3 mb-4">
    {{#for user in users}}
    <div class="card">
      <div class="flex items-center gap-4 mb-4">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" alt="{{user.username}}" width="48" height="48" style="border-radius: 50%;">
        {{#else}}
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          {{user.username}}
        </div>
        {{/if}}
        <div>
          <h4>{{user.username}}</h4>
          <p class="text-muted">{{user.email}}</p>
          <p class="text-muted">ID: {{user.id}}</p>
        </div>
      </div>

      {{! Role badge }}
      {{#switch user.role}}
      {{#case "admin"}}
      <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
      {{/case}}
      {{#case "editor"}}
      <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
      {{/case}}
      {{#case "viewer"}}
      <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
      {{/case}}
      {{/switch}}

      {{#if user.isActive}}
      <span class="badge text-success">Active</span>
      {{#else}}
      <span class="badge text-danger">Inactive</span>
      {{/if}}

      {{! Address info }}
      {{#with user.address}}
      <div class="mt-4">
        <p>{{street}}</p>
        <p>{{city.name}}, {{city.region.name}} {{zip}}</p>
        <p>{{country.name}} ({{country.currency.symbol}})</p>
        <p class="text-muted">TZ: {{city.region.timezone}}</p>
      </div>
      {{#empty}}
      <p class="text-muted mt-4">No address on file</p>
      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center;">No users in Quality Assurance department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Quality Assurance Product Listing --- }}
  <div class="card mb-4">
    <h3>Quality Assurance Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Quality Assurance Orders List --- }}
  <div class="card mb-4">
    <h3>Quality Assurance Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
          <span> - {{order.customer.username}} ({{order.customer.email}})</span>
        </div>
        <div class="flex items-center gap-2">
          {{#switch order.status}}
          {{#case "pending"}}
          <span class="badge" style="background: #fff3cd;">Pending</span>
          {{/case}}
          {{#case "processing"}}
          <span class="badge" style="background: #cce5ff;">Processing</span>
          {{/case}}
          {{#case "shipped"}}
          <span class="badge" style="background: #d1ecf1;">Shipped</span>
          {{/case}}
          {{#case "delivered"}}
          <span class="badge" style="background: #d4edda;">Delivered</span>
          {{/case}}
          {{#case "cancelled"}}
          <span class="badge" style="background: #f8d7da;">Cancelled</span>
          {{/case}}
          {{#case "refunded"}}
          <span class="badge" style="background: #e2e3e5;">Refunded</span>
          {{/case}}
          {{/switch}}
          <strong>{{currency}}{{order.total}}</strong>
        </div>
      </div>

      {{! Order items }}
      <div style="padding: 4px 0 0 20px;">
        {{#for item in order.items}}
        <div class="flex justify-between" style="padding: 2px 0;">
          <span>{{item.product.name}} ({{item.product.category.name}})</span>
          <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        </div>
        {{/for}}
      </div>

      {{! Shipping info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        <span>Ship: {{order.shipping.method}} via {{order.shipping.carrier}}</span>
        {{#if order.shipping.trackingNumber}}
        <span> | Track: {{order.shipping.trackingNumber}}</span>
        {{/if}}
        {{#if order.shipping.estimatedDelivery}}
        <span> | ETA: {{order.shipping.estimatedDelivery}}</span>
        {{/if}}
      </div>

      {{! Payment info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        {{#switch order.payment.method}}
        {{#case "credit_card"}}Credit Card{{/case}}
        {{#case "paypal"}}PayPal{{/case}}
        {{#case "bank_transfer"}}Bank Transfer{{/case}}
        {{#case "crypto"}}Crypto{{/case}}
        {{/switch}}
        -
        {{#switch order.payment.status}}
        {{#case "completed"}}<span class="text-success">Paid</span>{{/case}}
        {{#case "pending"}}<span class="text-warning">Pending</span>{{/case}}
        {{#case "failed"}}<span class="text-danger">Failed</span>{{/case}}
        {{#case "refunded"}}<span class="text-muted">Refunded</span>{{/case}}
        {{/switch}}
      </div>

      {{#if order.notes}}
      <div style="padding: 4px 0 0 20px;">
        <em>Note: {{order.notes}}</em>
      </div>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders in this section.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Quality Assurance Notifications --- }}
  <div class="card">
    <h3>Quality Assurance Notifications</h3>
    {{#for notif in notifications}}
    <div class="flex items-center gap-2" style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      {{#switch notif.kind}}
      {{#case "order"}}
      <span class="badge" style="background: #e8f5e9;">Order</span>
      <span>Order {{notif.orderId}} from {{notif.customerName}} - {{currency}}{{notif.total}}</span>
      {{/case}}
      {{#case "review"}}
      <span class="badge" style="background: #fff3e0;">Review</span>
      <span>{{notif.productName}} rated {{notif.rating}}/5 by {{notif.reviewerName}}</span>
      {{/case}}
      {{#case "system"}}
      <span class="badge" style="background: #e3f2fd;">System</span>
      <span>{{notif.title}}: {{notif.message}}</span>
      {{/case}}
      {{/switch}}
      <span class="text-muted">{{notif.timestamp}}</span>
      {{#if !notif.isRead}}
      <span class="badge text-success">New</span>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No notifications.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Legal Department (Section 11)                }}
{{! ============================================================ }}
<section id="legal-11" class="mb-4">
  <h2>Legal - Section 11</h2>

  {{! --- Legal User Cards --- }}
  <div class="grid grid-3 mb-4">
    {{#for user in users}}
    <div class="card">
      <div class="flex items-center gap-4 mb-4">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" alt="{{user.username}}" width="48" height="48" style="border-radius: 50%;">
        {{#else}}
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          {{user.username}}
        </div>
        {{/if}}
        <div>
          <h4>{{user.username}}</h4>
          <p class="text-muted">{{user.email}}</p>
          <p class="text-muted">ID: {{user.id}}</p>
        </div>
      </div>

      {{! Role badge }}
      {{#switch user.role}}
      {{#case "admin"}}
      <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
      {{/case}}
      {{#case "editor"}}
      <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
      {{/case}}
      {{#case "viewer"}}
      <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
      {{/case}}
      {{/switch}}

      {{#if user.isActive}}
      <span class="badge text-success">Active</span>
      {{#else}}
      <span class="badge text-danger">Inactive</span>
      {{/if}}

      {{! Address info }}
      {{#with user.address}}
      <div class="mt-4">
        <p>{{street}}</p>
        <p>{{city.name}}, {{city.region.name}} {{zip}}</p>
        <p>{{country.name}} ({{country.currency.symbol}})</p>
        <p class="text-muted">TZ: {{city.region.timezone}}</p>
      </div>
      {{#empty}}
      <p class="text-muted mt-4">No address on file</p>
      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center;">No users in Legal department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Legal Product Listing --- }}
  <div class="card mb-4">
    <h3>Legal Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Legal Orders List --- }}
  <div class="card mb-4">
    <h3>Legal Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
          <span> - {{order.customer.username}} ({{order.customer.email}})</span>
        </div>
        <div class="flex items-center gap-2">
          {{#switch order.status}}
          {{#case "pending"}}
          <span class="badge" style="background: #fff3cd;">Pending</span>
          {{/case}}
          {{#case "processing"}}
          <span class="badge" style="background: #cce5ff;">Processing</span>
          {{/case}}
          {{#case "shipped"}}
          <span class="badge" style="background: #d1ecf1;">Shipped</span>
          {{/case}}
          {{#case "delivered"}}
          <span class="badge" style="background: #d4edda;">Delivered</span>
          {{/case}}
          {{#case "cancelled"}}
          <span class="badge" style="background: #f8d7da;">Cancelled</span>
          {{/case}}
          {{#case "refunded"}}
          <span class="badge" style="background: #e2e3e5;">Refunded</span>
          {{/case}}
          {{/switch}}
          <strong>{{currency}}{{order.total}}</strong>
        </div>
      </div>

      {{! Order items }}
      <div style="padding: 4px 0 0 20px;">
        {{#for item in order.items}}
        <div class="flex justify-between" style="padding: 2px 0;">
          <span>{{item.product.name}} ({{item.product.category.name}})</span>
          <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        </div>
        {{/for}}
      </div>

      {{! Shipping info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        <span>Ship: {{order.shipping.method}} via {{order.shipping.carrier}}</span>
        {{#if order.shipping.trackingNumber}}
        <span> | Track: {{order.shipping.trackingNumber}}</span>
        {{/if}}
        {{#if order.shipping.estimatedDelivery}}
        <span> | ETA: {{order.shipping.estimatedDelivery}}</span>
        {{/if}}
      </div>

      {{! Payment info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        {{#switch order.payment.method}}
        {{#case "credit_card"}}Credit Card{{/case}}
        {{#case "paypal"}}PayPal{{/case}}
        {{#case "bank_transfer"}}Bank Transfer{{/case}}
        {{#case "crypto"}}Crypto{{/case}}
        {{/switch}}
        -
        {{#switch order.payment.status}}
        {{#case "completed"}}<span class="text-success">Paid</span>{{/case}}
        {{#case "pending"}}<span class="text-warning">Pending</span>{{/case}}
        {{#case "failed"}}<span class="text-danger">Failed</span>{{/case}}
        {{#case "refunded"}}<span class="text-muted">Refunded</span>{{/case}}
        {{/switch}}
      </div>

      {{#if order.notes}}
      <div style="padding: 4px 0 0 20px;">
        <em>Note: {{order.notes}}</em>
      </div>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders in this section.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Legal Notifications --- }}
  <div class="card">
    <h3>Legal Notifications</h3>
    {{#for notif in notifications}}
    <div class="flex items-center gap-2" style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      {{#switch notif.kind}}
      {{#case "order"}}
      <span class="badge" style="background: #e8f5e9;">Order</span>
      <span>Order {{notif.orderId}} from {{notif.customerName}} - {{currency}}{{notif.total}}</span>
      {{/case}}
      {{#case "review"}}
      <span class="badge" style="background: #fff3e0;">Review</span>
      <span>{{notif.productName}} rated {{notif.rating}}/5 by {{notif.reviewerName}}</span>
      {{/case}}
      {{#case "system"}}
      <span class="badge" style="background: #e3f2fd;">System</span>
      <span>{{notif.title}}: {{notif.message}}</span>
      {{/case}}
      {{/switch}}
      <span class="text-muted">{{notif.timestamp}}</span>
      {{#if !notif.isRead}}
      <span class="badge text-success">New</span>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No notifications.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Executive Department (Section 12)                }}
{{! ============================================================ }}
<section id="executive-12" class="mb-4">
  <h2>Executive - Section 12</h2>

  {{! --- Executive User Cards --- }}
  <div class="grid grid-3 mb-4">
    {{#for user in users}}
    <div class="card">
      <div class="flex items-center gap-4 mb-4">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" alt="{{user.username}}" width="48" height="48" style="border-radius: 50%;">
        {{#else}}
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          {{user.username}}
        </div>
        {{/if}}
        <div>
          <h4>{{user.username}}</h4>
          <p class="text-muted">{{user.email}}</p>
          <p class="text-muted">ID: {{user.id}}</p>
        </div>
      </div>

      {{! Role badge }}
      {{#switch user.role}}
      {{#case "admin"}}
      <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
      {{/case}}
      {{#case "editor"}}
      <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
      {{/case}}
      {{#case "viewer"}}
      <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
      {{/case}}
      {{/switch}}

      {{#if user.isActive}}
      <span class="badge text-success">Active</span>
      {{#else}}
      <span class="badge text-danger">Inactive</span>
      {{/if}}

      {{! Address info }}
      {{#with user.address}}
      <div class="mt-4">
        <p>{{street}}</p>
        <p>{{city.name}}, {{city.region.name}} {{zip}}</p>
        <p>{{country.name}} ({{country.currency.symbol}})</p>
        <p class="text-muted">TZ: {{city.region.timezone}}</p>
      </div>
      {{#empty}}
      <p class="text-muted mt-4">No address on file</p>
      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center;">No users in Executive department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Executive Product Listing --- }}
  <div class="card mb-4">
    <h3>Executive Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Executive Orders List --- }}
  <div class="card mb-4">
    <h3>Executive Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
          <span> - {{order.customer.username}} ({{order.customer.email}})</span>
        </div>
        <div class="flex items-center gap-2">
          {{#switch order.status}}
          {{#case "pending"}}
          <span class="badge" style="background: #fff3cd;">Pending</span>
          {{/case}}
          {{#case "processing"}}
          <span class="badge" style="background: #cce5ff;">Processing</span>
          {{/case}}
          {{#case "shipped"}}
          <span class="badge" style="background: #d1ecf1;">Shipped</span>
          {{/case}}
          {{#case "delivered"}}
          <span class="badge" style="background: #d4edda;">Delivered</span>
          {{/case}}
          {{#case "cancelled"}}
          <span class="badge" style="background: #f8d7da;">Cancelled</span>
          {{/case}}
          {{#case "refunded"}}
          <span class="badge" style="background: #e2e3e5;">Refunded</span>
          {{/case}}
          {{/switch}}
          <strong>{{currency}}{{order.total}}</strong>
        </div>
      </div>

      {{! Order items }}
      <div style="padding: 4px 0 0 20px;">
        {{#for item in order.items}}
        <div class="flex justify-between" style="padding: 2px 0;">
          <span>{{item.product.name}} ({{item.product.category.name}})</span>
          <span>{{item.quantity}} x {{../../currency}}{{item.unitPrice}} = {{../../currency}}{{item.unitPrice * item.quantity}}</span>
        </div>
        {{/for}}
      </div>

      {{! Shipping info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        <span>Ship: {{order.shipping.method}} via {{order.shipping.carrier}}</span>
        {{#if order.shipping.trackingNumber}}
        <span> | Track: {{order.shipping.trackingNumber}}</span>
        {{/if}}
        {{#if order.shipping.estimatedDelivery}}
        <span> | ETA: {{order.shipping.estimatedDelivery}}</span>
        {{/if}}
      </div>

      {{! Payment info }}
      <div style="padding: 4px 0 0 20px;" class="text-muted">
        {{#switch order.payment.method}}
        {{#case "credit_card"}}Credit Card{{/case}}
        {{#case "paypal"}}PayPal{{/case}}
        {{#case "bank_transfer"}}Bank Transfer{{/case}}
        {{#case "crypto"}}Crypto{{/case}}
        {{/switch}}
        -
        {{#switch order.payment.status}}
        {{#case "completed"}}<span class="text-success">Paid</span>{{/case}}
        {{#case "pending"}}<span class="text-warning">Pending</span>{{/case}}
        {{#case "failed"}}<span class="text-danger">Failed</span>{{/case}}
        {{#case "refunded"}}<span class="text-muted">Refunded</span>{{/case}}
        {{/switch}}
      </div>

      {{#if order.notes}}
      <div style="padding: 4px 0 0 20px;">
        <em>Note: {{order.notes}}</em>
      </div>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No orders in this section.</p>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Executive Notifications --- }}
  <div class="card">
    <h3>Executive Notifications</h3>
    {{#for notif in notifications}}
    <div class="flex items-center gap-2" style="padding: 8px 0; border-bottom: 1px solid #f0f0f0;">
      {{#switch notif.kind}}
      {{#case "order"}}
      <span class="badge" style="background: #e8f5e9;">Order</span>
      <span>Order {{notif.orderId}} from {{notif.customerName}} - {{currency}}{{notif.total}}</span>
      {{/case}}
      {{#case "review"}}
      <span class="badge" style="background: #fff3e0;">Review</span>
      <span>{{notif.productName}} rated {{notif.rating}}/5 by {{notif.reviewerName}}</span>
      {{/case}}
      {{#case "system"}}
      <span class="badge" style="background: #e3f2fd;">System</span>
      <span>{{notif.title}}: {{notif.message}}</span>
      {{/case}}
      {{/switch}}
      <span class="text-muted">{{notif.timestamp}}</span>
      {{#if !notif.isRead}}
      <span class="badge text-success">New</span>
      {{/if}}
    </div>
    {{#empty}}
    <p class="text-muted">No notifications.</p>
    {{/empty}}
    {{/for}}
  </div>
</section>


{{! ============================================================ }}
{{! SECTION: Logistics Department (Section 13)                }}
{{! ============================================================ }}
<section id="logistics-13" class="mb-4">
  <h2>Logistics - Section 13</h2>

  {{! --- Logistics User Cards --- }}
  <div class="grid grid-3 mb-4">
    {{#for user in users}}
    <div class="card">
      <div class="flex items-center gap-4 mb-4">
        {{#if user.avatar}}
        <img src="{{user.avatar}}" alt="{{user.username}}" width="48" height="48" style="border-radius: 50%;">
        {{#else}}
        <div style="width: 48px; height: 48px; border-radius: 50%; background: #e0e0e0; display: flex; align-items: center; justify-content: center;">
          {{user.username}}
        </div>
        {{/if}}
        <div>
          <h4>{{user.username}}</h4>
          <p class="text-muted">{{user.email}}</p>
          <p class="text-muted">ID: {{user.id}}</p>
        </div>
      </div>

      {{! Role badge }}
      {{#switch user.role}}
      {{#case "admin"}}
      <span class="badge" style="background: #fef3c7; color: #92400e;">Admin</span>
      {{/case}}
      {{#case "editor"}}
      <span class="badge" style="background: #d1fae5; color: #065f46;">Editor</span>
      {{/case}}
      {{#case "viewer"}}
      <span class="badge" style="background: #e0e7ff; color: #3730a3;">Viewer</span>
      {{/case}}
      {{/switch}}

      {{#if user.isActive}}
      <span class="badge text-success">Active</span>
      {{#else}}
      <span class="badge text-danger">Inactive</span>
      {{/if}}

      {{! Address info }}
      {{#with user.address}}
      <div class="mt-4">
        <p>{{street}}</p>
        <p>{{city.name}}, {{city.region.name}} {{zip}}</p>
        <p>{{country.name}} ({{country.currency.symbol}})</p>
        <p class="text-muted">TZ: {{city.region.timezone}}</p>
      </div>
      {{#empty}}
      <p class="text-muted mt-4">No address on file</p>
      {{/empty}}
      {{/with}}

      {{! Preferences }}
      <div class="mt-4">
        <p>Theme: {{user.preferences.theme}} | Lang: {{user.preferences.language}}</p>
        <p>Display: {{user.preferences.display.itemsPerPage}} items/page</p>
        {{#if user.preferences.display.compactMode}}
        <span class="badge">Compact</span>
        {{/if}}
        {{#if user.preferences.display.showSidebar}}
        <span class="badge">Sidebar</span>
        {{/if}}
        <p>Notifications: {{#switch user.preferences.notifications.frequency}}
        {{#case "instant"}}Instant{{/case}}
        {{#case "daily"}}Daily{{/case}}
        {{#case "weekly"}}Weekly{{/case}}
        {{/switch}}</p>
      </div>

      {{! Role-specific details }}
      {{#if user.isSuperAdmin}}
      <div class="mt-4" style="background: #fefce8; padding: 8px; border-radius: 4px;">
        <p><strong>Admin Info</strong></p>
        <p>Dept: {{user.department}} | Level: {{user.accessLevel}}</p>
        {{#for perm in user.permissions}}
        <span class="badge">{{perm}}</span>
        {{/for}}
      </div>
      {{#else if user.bio}}
      <div class="mt-4" style="background: #ecfdf5; padding: 8px; border-radius: 4px;">
        <p><strong>Editor Info</strong></p>
        <p>{{user.bio}}</p>
        <p>Published: {{user.publishedCount}} | Drafts: {{user.draftCount}}</p>
        {{#for cat in user.assignedCategories}}
        <span class="badge">{{cat}}</span>
        {{/for}}
      </div>
      {{#else if user.favoriteCount}}
      <div class="mt-4" style="background: #eef2ff; padding: 8px; border-radius: 4px;">
        <p><strong>Viewer Info</strong></p>
        <p>Registered: {{user.registeredAt}}</p>
        <p>Favorites: {{user.favoriteCount}}</p>
      </div>
      {{/if}}

      {{! Action buttons }}
      <div class="flex gap-2 mt-4">
        <button class="btn btn-primary">View Profile</button>
        <button class="btn">Message</button>
        {{#if user.isActive}}
        <button class="btn btn-danger">Suspend</button>
        {{#else}}
        <button class="btn btn-success">Reactivate</button>
        {{/if}}
      </div>

      <p class="text-muted mt-4">Position: {{@index}} of {{@length}} (First) (Last)</p>
    </div>
    {{#empty}}
    <div class="card" style="grid-column: 1 / -1;">
      <p class="text-muted" style="text-align: center;">No users in Logistics department.</p>
    </div>
    {{/empty}}
    {{/for}}
  </div>

  {{! --- Logistics Product Listing --- }}
  <div class="card mb-4">
    <h3>Logistics Products</h3>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Name</th>
          <th>Category</th>
          <th>Price</th>
          <th>Rating</th>
          <th>Stock</th>
          <th>Tags</th>
          <th>Dimensions</th>
        </tr>
      </thead>
      <tbody>
        {{#for product in products}}
        <tr>
          <td>{{@index}}</td>
          <td>
            <strong>{{product.name}}</strong>
            <p class="text-muted">{{product.shortDescription}}</p>
          </td>
          <td>
            <span>{{product.category.name}}</span>
            {{#if product.category.parentCategory}}
            <span class="text-muted"> ({{product.category.parentCategory}})</span>
            {{/if}}
          </td>
          <td>
            <strong>{{currency}}{{product.price}}</strong>
            {{#if product.compareAtPrice}}
            <br><span style="text-decoration: line-through;" class="text-muted">{{currency}}{{product.compareAtPrice}}</span>
            {{/if}}
            {{#if product.isOnSale}}
            <br><span class="text-danger">SALE</span>
            {{/if}}
          </td>
          <td>{{product.averageRating}}/5 ({{product.reviewCount}})</td>
          <td>
            {{#if product.inStock}}
            <span class="text-success">In Stock</span>
            {{#else}}
            <span class="text-danger">Out of Stock</span>
            {{/if}}
          </td>
          <td>
            {{#for tag in product.tags}}
            <span class="badge">{{tag}}</span>
            {{/for}}
          </td>
          <td>
            {{product.dimensions.length}}x{{product.dimensions.width}}x{{product.dimensions.height}} {{product.dimensions.unit}}
            <br>{{product.weight}}kg
          </td>
        </tr>

        {{! Variants sub-table }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Variants:</p>
            {{#for variant in product.variants}}
            <div class="flex justify-between" style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <span>{{variant.name}} ({{variant.sku}})</span>
              <span>
                {{../../currency}}{{variant.price}}
                {{#if variant.compareAtPrice}}
                <span style="text-decoration: line-through;" class="text-muted">{{../../currency}}{{variant.compareAtPrice}}</span>
                {{/if}}
                {{#if variant.inStock}}
                <span class="text-success">({{variant.stockQuantity}} left)</span>
                {{#else}}
                <span class="text-danger">(sold out)</span>
                {{/if}}
              </span>
            </div>
            <div style="padding-left: 16px;">
              {{#for attr in variant.attributes}}
              <span class="badge">{{attr.name}}: {{attr.value}}</span>
              {{/for}}
            </div>
            {{#empty}}
            <span class="text-muted">No variants</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>

        {{! Reviews sub-section }}
        <tr>
          <td colspan="8" style="padding-left: 32px;">
            <p class="text-muted">Reviews ({{product.reviewCount}}):</p>
            {{#for review in product.reviews}}
            <div style="padding: 4px 0; border-bottom: 1px dotted #eee;">
              <div class="flex justify-between">
                <strong>{{review.title}}</strong>
                <span>{{review.rating}}/5 {{#if review.verified}}<span class="text-success">Verified</span>{{/if}}</span>
              </div>
              <p>{{review.body}}</p>
              <p class="text-muted">by {{review.author}} on {{review.date}} | {{review.helpfulCount}} found helpful</p>
            </div>
            {{#empty}}
            <span class="text-muted">No reviews yet</span>
            {{/empty}}
            {{/for}}
          </td>
        </tr>
        {{#empty}}
        <tr>
          <td colspan="8" class="text-muted" style="text-align: center;">No products.</td>
        </tr>
        {{/empty}}
        {{/for}}
      </tbody>
    </table>
  </div>

  {{! --- Logistics Orders List --- }}
  <div class="card mb-4">
    <h3>Logistics Recent Orders</h3>
    {{#for order in orders}}
    <div style="padding: 12px 0; border-bottom: 1px solid #f0f0f0;">
      <div class="flex justify-between items-center">
        <div>
          <strong>#{{order.orderNumber}}</strong>
